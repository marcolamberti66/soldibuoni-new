---
import Layout from '../layouts/Layout.astro';
import { ForfettarioVsOrdinario } from '../components/ForfettarioVsOrdinario.jsx';

const topic = {
  icon: '📋',
  title: 'Forfettario vs Ordinario',
  color: '#6366f1'
};
---

<Layout 
  title="Regime Forfettario o Ordinario: quale conviene? | SoldiBuoni" 
  description="Calcola quale regime fiscale conviene di più alla tua partita IVA. Confronto tra forfettario al 5% o 15% e ordinario con IRPEF progressiva, addizionali e gestione separata INPS."
>
  <div style="max-width: 880px; margin: 0 auto; padding: 36px 20px 80px;">
    
    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 10px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; background: ${topic.color}14;`}>
        {topic.icon}
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 30px; color: #0f172a;">
        {topic.title}
      </h1>
    </div>

    <p class="intro-text">Simula il netto annuo della tua partita IVA nei due regimi fiscali. Il calcolo considera IRPEF progressiva, addizionali regionale e comunale medie, coefficiente di redditività e contributi INPS.</p>

    <ForfettarioVsOrdinario client:load color={topic.color} />

  </div>
</Layout>

<style>
  .intro-text {
    font-size: 15px;
    color: #64748b;
    margin: 0 0 32px 0;
    line-height: 1.65;
    max-width: 640px;
  }
</style>