---
import Layout from '../layouts/Layout.astro';
import { TOPICS } from '../data.js';

const topic = TOPICS.acqua;
---

<Layout title="Bolletta Acqua — Calcola e Ottimizza | SoldiBuoni" description="Calcola il consumo idrico della tua famiglia, scopri come risparmiare e verifica se hai diritto al bonus idrico.">
  <div style="max-width: 880px; margin: 0 auto; padding: 36px 20px 80px;">
    
    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 28px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; background: ${topic.color}14;`}>
        {topic.icon}
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 30px; color: #0f172a;">
        {topic.title}
      </h1>
    </div>

    <div class="tab-container" style={`--theme-color: ${topic.color}`}>
      <button class="tab-btn active" data-target="tab-calc">💧 Calcolatore</button>
      <button class="tab-btn" data-target="tab-capire">💡 Capire la bolletta</button>
      <button class="tab-btn" data-target="tab-guida">🛠️ Come ottimizzare</button>
    </div>

    <div id="tab-calc" class="tab-content" style="display: block;">
      <h2 style="font-family: 'Playfair Display',serif; font-size: 24px; color: #0f172a; margin-bottom: 18px;">
        Calcolatore Consumo Idrico
      </h2>

      <div style="background: #fff; border-radius: 14px; padding: 22px; border: 1px solid #e2e8f0; margin-bottom: 16px;">
        <label style="font-size: 14px; font-weight: 600; color: #0f172a; display: block; margin-bottom: 8px;">
          Componenti del nucleo: <span id="pers-value" style="color: #3B82F6;">3 persone</span>
        </label>
        <input type="range" id="pers-slider" min="1" max="6" step="1" value="3" style="width: 100%; accent-color: #3B82F6;">
        <div style="display: flex; justify-content: space-between; font-size: 12px; color: #94a3b8;">
          <span>1</span><span>6 persone</span>
        </div>
      </div>

      <div style="background: #fff; border-radius: 14px; padding: 22px; border: 1px solid #e2e8f0; margin-bottom: 16px;">
        <p style="font-size: 14px; font-weight: 600; color: #0f172a; margin-bottom: 10px;">Le tue abitudini</p>
        <div id="habits">
          <label class="habit-row"><input type="checkbox" id="h-giardino"> 🌿 Ho un giardino/orto da irrigare</label>
          <label class="habit-row"><input type="checkbox" id="h-lavastoviglie" checked> 🍽️ Uso la lavastoviglie</label>
          <label class="habit-row"><input type="checkbox" id="h-vasca"> 🛁 Faccio il bagno nella vasca (non solo doccia)</label>
          <label class="habit-row"><input type="checkbox" id="h-riduttori"> 🔧 Ho riduttori di flusso ai rubinetti</label>
          <label class="habit-row"><input type="checkbox" id="h-doppio"> 🚽 Ho cassette WC a doppio scarico</label>
        </div>
      </div>

      <!-- RISULTATI -->
      <div style="background: linear-gradient(135deg, #0c4a6e, #1e40af); border-radius: 16px; padding: 28px; color: #fff; margin-bottom: 16px;">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; text-align: center;">
          <div>
            <div style="font-size: 12px; color: #93c5fd; margin-bottom: 4px;">Consumo annuo</div>
            <div id="res-mc" style="font-size: 28px; font-weight: 800; font-family: 'Playfair Display',serif;">180 mc</div>
          </div>
          <div>
            <div style="font-size: 12px; color: #93c5fd; margin-bottom: 4px;">Bolletta stimata</div>
            <div id="res-euro" style="font-size: 28px; font-weight: 800; font-family: 'Playfair Display',serif; color: #60a5fa;">€396</div>
          </div>
          <div>
            <div style="font-size: 12px; color: #93c5fd; margin-bottom: 4px;">Litri/persona/giorno</div>
            <div id="res-litri" style="font-size: 28px; font-weight: 800; font-family: 'Playfair Display',serif;">164 L</div>
          </div>
        </div>

        <div id="bonus-box" style="margin-top: 18px; background: rgba(255,255,255,0.1); border-radius: 10px; padding: 14px; display: none;">
          <p style="font-size: 13px; color: #93c5fd;">💰 <strong style="color: #fff;">Potresti avere diritto al Bonus Idrico!</strong> Con ISEE sotto €8.265 (o €20.000 con 4+ figli) puoi richiedere l'agevolazione tramite ISEE all'INPS.</p>
        </div>
      </div>

      <!-- CONSIGLI RISPARMIO -->
      <div style="background: #fff; border-radius: 14px; padding: 22px; border: 1px solid #e2e8f0;">
        <h3 style="font-size: 15px; font-weight: 700; color: #0f172a; margin-bottom: 14px;">💡 Potenziale di risparmio</h3>
        <div id="savings-tips"></div>
      </div>

      <p style="font-size: 11px; color: #94a3b8; margin-top: 14px; font-style: italic; text-align: center;">
        * Stime basate su tariffe medie ARERA 2025/2026. La tariffa varia per zona e gestore.
      </p>
    </div>

    <div id="tab-capire" class="tab-content" style="display: none;">
      <h2 style="font-family: 'Playfair Display',serif; font-size: 24px; color: #0f172a; margin-bottom: 24px;">{topic.capire.title}</h2>
      {topic.capire.content.map((c) => (
        <div style="background: #fff; border-radius: 14px; padding: 24px; margin-bottom: 14px; border: 1px solid #e2e8f0;">
          <h3 style={`color: ${topic.color}; font-size: 15px; font-weight: 700; margin-bottom: 8px;`}>{c.subtitle}</h3>
          <p style="color: #475569; font-size: 14px; line-height: 1.75;">{c.text}</p>
        </div>
      ))}
    </div>

    <div id="tab-guida" class="tab-content" style="display: none;">
      <h2 style="font-family: 'Playfair Display',serif; font-size: 24px; color: #0f172a; margin-bottom: 24px;">{topic.guida.title}</h2>
      <div style="display: flex; flex-direction: column; gap: 14px;">
        {topic.guida.steps.map((s) => (
          <div style="background: #fff; border-radius: 14px; padding: 20px 24px; border: 1px solid #e2e8f0; display: flex; gap: 16px;">
            <div style={`width: 32px; height: 32px; border-radius: 50%; background: ${topic.color}; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;`}>{s.n}</div>
            <div>
              <h3 style="color: #0f172a; font-size: 16px; font-weight: 700; margin-bottom: 6px;">{s.title}</h3>
              <p style="color: #475569; font-size: 14px; line-height: 1.6;">{s.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .tab-container { display: flex; gap: 8px; margin-bottom: 30px; background: #fff; padding: 6px; border-radius: 12px; border: 1px solid #e2e8f0; }
  .tab-btn { flex: 1; background: transparent; border: none; padding: 12px 0; border-radius: 8px; font-size: 14px; font-weight: 600; color: #64748b; cursor: pointer; transition: all 0.2s; font-family: inherit; }
  .tab-btn:hover { background: #f8fafc; }
  .tab-btn.active { background: var(--theme-color); color: #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
  .tab-content { animation: fadeIn 0.3s ease-in-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .habit-row { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; cursor: pointer; font-size: 14px; color: #0f172a; transition: background 0.2s; margin-bottom: 4px; }
  .habit-row:hover { background: #f8fafc; }
  .habit-row input { width: 18px; height: 18px; accent-color: #3B82F6; }
  @media (max-width: 768px) {
    .tab-container { flex-direction: column; }
    [style*="grid-template-columns: repeat(3"] { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
      btn.classList.add('active');
      document.getElementById(btn.getAttribute('data-target')).style.display = 'block';
    });
  });

  const persSlider = document.getElementById('pers-slider');
  const checkboxes = ['h-giardino', 'h-lavastoviglie', 'h-vasca', 'h-riduttori', 'h-doppio'];

  function calculate() {
    const pers = +persSlider.value;
    const giardino = document.getElementById('h-giardino').checked;
    const lavastoviglie = document.getElementById('h-lavastoviglie').checked;
    const vasca = document.getElementById('h-vasca').checked;
    const riduttori = document.getElementById('h-riduttori').checked;
    const doppio = document.getElementById('h-doppio').checked;

    // Base: 55 mc/persona/anno
    let mcPerPersona = 55;
    if (vasca) mcPerPersona += 12;
    if (!lavastoviglie) mcPerPersona += 5; // lavi a mano = più acqua
    if (riduttori) mcPerPersona -= 15;
    if (doppio) mcPerPersona -= 8;

    let mcTotale = mcPerPersona * pers;
    if (giardino) mcTotale += 40;

    // Tariffa media ARERA: ~2.2 €/mc (media pesata con fasce)
    const tariffa = 2.2;
    const quotaFissa = 45; // €/anno
    const bolletta = mcTotale * tariffa + quotaFissa;
    const litriGiorno = Math.round((mcTotale * 1000) / 365 / pers);

    document.getElementById('pers-value').textContent = pers + (pers === 1 ? ' persona' : ' persone');
    document.getElementById('res-mc').textContent = Math.round(mcTotale) + ' mc';
    document.getElementById('res-euro').textContent = '€' + Math.round(bolletta);
    document.getElementById('res-litri').textContent = litriGiorno + ' L';

    // Bonus box
    document.getElementById('bonus-box').style.display = pers >= 4 ? 'block' : 'none';

    // Savings tips
    const tips = [];
    if (!riduttori) tips.push({ text: 'Installa riduttori di flusso', save: Math.round(15 * pers * tariffa), cost: '€20 una tantum', icon: '🔧' });
    if (!doppio) tips.push({ text: 'Cassette WC a doppio scarico', save: Math.round(8 * pers * tariffa), cost: '€30-60 per WC', icon: '🚽' });
    if (vasca) tips.push({ text: 'Doccia invece del bagno', save: Math.round(12 * pers * tariffa), cost: 'Gratis', icon: '🚿' });
    if (giardino) tips.push({ text: 'Raccolta acqua piovana per giardino', save: Math.round(25 * tariffa), cost: '€50-100 serbatoio', icon: '🌧️' });
    if (!lavastoviglie) tips.push({ text: 'Usa la lavastoviglie (meno acqua del lavaggio a mano)', save: Math.round(5 * pers * tariffa), cost: 'Se già ce l\'hai', icon: '🍽️' });

    const tipsTotal = tips.reduce((s, t) => s + t.save, 0);
    let html = tips.map(t => `
      <div style="display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #f1f5f9;">
        <span style="font-size: 20px;">${t.icon}</span>
        <div style="flex: 1;">
          <span style="font-size: 13px; font-weight: 600; color: #0f172a;">${t.text}</span>
          <span style="font-size: 12px; color: #94a3b8; display: block;">${t.cost}</span>
        </div>
        <span style="font-size: 14px; font-weight: 700; color: #059669;">-€${t.save}/anno</span>
      </div>
    `).join('');

    if (tipsTotal > 0) {
      html += `<div style="margin-top: 14px; background: #f0fdf4; border-radius: 10px; padding: 12px; text-align: center;">
        <span style="font-size: 14px; font-weight: 700; color: #059669;">Risparmio totale potenziale: €${tipsTotal}/anno</span>
      </div>`;
    } else {
      html = '<p style="font-size: 14px; color: #059669; text-align: center; padding: 16px;">Ottimo! Stai già ottimizzando il consumo idrico ✓</p>';
    }
    document.getElementById('savings-tips').innerHTML = html;
  }

  persSlider.addEventListener('input', calculate);
  checkboxes.forEach(id => document.getElementById(id).addEventListener('change', calculate));
  calculate();
</script>
