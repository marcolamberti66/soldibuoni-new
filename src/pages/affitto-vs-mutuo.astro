---
import Layout from '../layouts/Layout.astro';
import { AffittoVsMutuo } from '../components/AffittoVsMutuo.jsx';

const topic = {
  icon: '🏠',
  title: 'Affitto vs Mutuo',
  color: '#10b981'
};
---

<Layout 
  title="Affitto vs Mutuo: quale conviene? | SoldiBuoni" 
  description="Scopri dopo quanti anni comprare casa diventa più conveniente che affittare. Simulatore con grafico break-even basato su rata, IMU, manutenzione e costo opportunità."
>
  <div style="max-width: 880px; margin: 0 auto; padding: 36px 20px 80px;">
    
    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 10px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; background: ${topic.color}14;`}>
        {topic.icon}
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 30px; color: #0f172a;">
        {topic.title}
      </h1>
    </div>

    <p class="intro-text">Scopri dopo quanti anni comprare casa diventa più conveniente che continuare ad affittare. Il simulatore considera rata, IMU, manutenzione, spese d'acquisto e il costo opportunità dell'anticipo.</p>

    <AffittoVsMutuo client:load color={topic.color} />

  </div>
</Layout>

<style>
  .intro-text {
    font-size: 15px;
    color: #64748b;
    margin: 0 0 32px 0;
    line-height: 1.65;
    max-width: 640px;
  }
</style>