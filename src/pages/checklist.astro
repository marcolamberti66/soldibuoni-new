---
import Layout from '../layouts/Layout.astro';
import ChecklistRisparmio from '../components/ChecklistRisparmio.jsx';

const color = '#8b5cf6';
---

<Layout title="Checklist Risparmio — 12 Azioni Concrete per Risparmiare | SoldiBuoni" description="12 azioni concrete per risparmiare fino a €4.000/anno su bollette, auto, casa e previdenza. Spunta quelle completate e tieni traccia del tuo progresso.">

  <div style="max-width: 960px; margin: 0 auto; padding: 36px 20px 80px;">

    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 10px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; background: ${color}14; flex-shrink: 0;`}>
        ✅
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 30px; font-weight: 800; color: #0f172a; margin: 0;">
        Checklist <span style={`color: ${color};`}>Salvavita</span>
      </h1>
    </div>

    <p class="update-note">🔄 12 azioni ordinate per impatto · Progresso salvato nel tuo browser · Aggiornata aprile 2026</p>

    <p style="font-size: 15px; color: #475569; line-height: 1.7; margin: 0 0 28px; max-width: 640px;">
      Una cosa al mese, senza stress. Ogni azione ha il risparmio stimato, il tempo richiesto e il link al tool giusto. Spunta quelle completate: il progresso resta salvato nel tuo browser.
    </p>

    <ChecklistRisparmio client:load />

    <div style="margin-top: 32px; padding: 20px 24px; background: linear-gradient(135deg, #eff6ff 0%, #fff 60%); border: 1px solid rgba(59,130,246,0.2); border-radius: 20px; display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;">
      <div style="flex: 1 1 280px;">
        <h4 style="font-size: 16px; font-weight: 800; color: #0f172a; margin: 0 0 4px;">Vuoi capire il metodo dietro queste azioni?</h4>
        <p style="font-size: 13px; color: #64748b; margin: 0; line-height: 1.5;">La Guida Risparmio 2026 spiega il perché di ogni strategia, con dati e calcoli reali.</p>
      </div>
      <a href="/guida-risparmio" style="padding: 12px 20px; border-radius: 12px; background: #3b82f6; color: #fff; font-size: 13px; font-weight: 800; text-decoration: none; white-space: nowrap; box-shadow: 0 6px 16px -4px rgba(59,130,246,0.5);">
        Leggi la guida →
      </a>
    </div>

  </div>

</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .update-note {
    font-size: 12px;
    color: #94a3b8;
    margin: 0 0 20px 0;
    padding-left: 2px;
    font-weight: 500;
  }
</style>