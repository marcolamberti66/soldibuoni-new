---
import Layout from '../layouts/Layout.astro';
import { CarburanteComp } from '../components/CarburanteComp.jsx';
---

<Layout 
  title="Calcolatore Costi Mobilità | SoldiBuoni" 
  description="Confronta i costi reali al chilometro di Benzina, Diesel, GPL e Auto Elettrica."
>
  <div style="max-width: 1080px; margin: 0 auto; padding: 60px 20px;">
    
    <div style="text-align: center; margin-bottom: 48px;">
      <h1 style="font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 800; color: #0f172a; margin-bottom: 16px; letter-spacing: -1px;">
        Quanto ti costa <span style="color: #06b6d4;">muoverti?</span>
      </h1>
      <p style="font-size: 18px; color: #64748b; max-width: 600px; margin: 0 auto; line-height: 1.6;">
        Inserisci i tuoi chilometri annui e scopri la spesa reale basata sui prezzi medi attuali di carburante ed energia elettrica.
      </p>
    </div>

    <CarburanteComp client:load color="#06b6d4" />

  </div>
</Layout>
