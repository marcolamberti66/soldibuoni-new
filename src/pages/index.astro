---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
---

<Layout title="Soldi Buoni — Impara, Risparmia, Gestisci le tue Finanze" description="Strumenti gratuiti, offerte selezionate e guide pratiche per ottimizzare le finanze della tua famiglia. Comparatori imparziali per bollette, assicurazioni e mutui.">
  
  <section class="hero">
    <div class="hero-bg-mesh">
      <div class="mesh-blob blob-1"></div>
      <div class="mesh-blob blob-2"></div>
      <div class="mesh-blob blob-3"></div>
    </div>
    <div class="hero-inner">
      <div class="hero-pill-badge">🚀 Nuovo strumento AI gratuito</div>
      <h1 class="hero-title">
        I tuoi soldi meritano<br/>un'attenzione <span class="hero-accent">premium.</span>
      </h1>
      <p class="hero-sub">
        L'eccellenza della tecnologia finanziaria al servizio della tua famiglia.<br class="hide-mobile"/>
        Analizza, confronta e gestisci ogni spesa in pochi secondi.
      </p>
      <div class="hero-ctas">
        <a href="/quanto-spendo" class="hero-btn-glow">🧮 Calcola quanto spendi →</a>
        <a href="#risparmia" class="hero-btn-glass">💸 Esplora le offerte</a>
      </div>
    </div>
  </section>

  <div class="trust-strip">
    <div class="trust-inner">
      <div class="trust-stars">
        <span class="stars">★★★★★</span>
        <span class="trust-score">4.8/5</span>
        <span class="trust-text">Oltre <strong>2.500 famiglie</strong> hanno ottimizzato le spese.</span>
      </div>
    </div>
  </div>

  <div class="page-content">

    <section id="impara" class="pillar">
      <div class="pillar-header">
        <span class="pillar-badge pillar-badge-blue">Educazione Finanziaria</span>
        <h2 class="pillar-title">Impara e Analizza.</h2>
        <p class="pillar-sub">Algoritmi avanzati per diagnosticare la tua situazione economica in tempo reale.</p>
      </div>

      <div class="tools-duo">
        <a href="/quanto-spendo" class="tool-card tool-premium-dark">
          <div class="tool-top">
            <div class="icon-squircle glass-squircle">🧮</div>
            <span class="tool-label">Stima Immediata</span>
          </div>
          <h3 class="tool-name">Quanto Spendo?</h3>
          <p class="tool-desc">Tre domande, 60 secondi. Scopri l'esatta emorragia finanziaria annuale della tua famiglia e sblocca il piano d'azione.</p>
          <span class="tool-cta">Avvia la Diagnosi →</span>
        </a>
        <a href="/analisi-bolletta" class="tool-card tool-premium-emerald">
          <div class="tool-top">
            <div class="icon-squircle glass-squircle">🔍</div>
            <span class="tool-label">Intelligenza Artificiale</span>
          </div>
          <h3 class="tool-name">Analizza Bolletta</h3>
          <p class="tool-desc">Trascina il PDF. La nostra AI (modello Sonnet 3.5) estrae i costi, applica il filtro privacy GDPR e calcola il risparmio al centesimo.</p>
          <span class="tool-cta">Analizza Ora →</span>
        </a>
      </div>

      <div class="resources-row">
        <a href="/guida-risparmio" class="resource-card">
          <div class="icon-squircle" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">📖</div>
          <div class="resource-info">
            <strong>Guida Risparmio 2026</strong>
            <span>Le 10 strategie definitive</span>
          </div>
        </a>
        <a href="/checklist" class="resource-card">
          <div class="icon-squircle" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">✅</div>
          <div class="resource-info">
            <strong>Checklist 12 Azioni</strong>
            <span>Sblocca fino a €4.000/anno</span>
          </div>
        </a>
        <a href="/mutuo" class="resource-card">
          <div class="icon-squircle" style="background: rgba(139, 92, 246, 0.1); color: #8b5cf6;">🏠</div>
          <div class="resource-info">
            <strong>Simulatore Mutui</strong>
            <span>Tassi, ammortamento, surroga</span>
          </div>
        </a>
        <a href="/carburante" class="resource-card">
          <div class="icon-squircle" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">⛽</div>
          <div class="resource-info">
            <strong>Analisi Mobilità</strong>
            <span>Benzina vs Elettrico (TCO)</span>
          </div>
        </a>
      </div>
    </section>

    <section id="risparmia" class="pillar">
      <div class="pillar-header">
        <span class="pillar-badge pillar-badge-green">Ottimizzazione Attiva</span>
        <h2 class="pillar-title">Taglia le Spese.</h2>
        <p class="pillar-sub">Le migliori offerte del mercato, filtrate da noi, aggiornate via API.</p>
      </div>

      <div class="offers-grid">
        <a href="/energia" class="offer-card-premium">
          <div class="offer-card-top">
            <div class="icon-squircle" style="background: #fef3c7; color: #d97706; font-size: 28px;">⚡</div>
            <div class="offer-headers">
              <h3 class="offer-name">Energia Elettrica</h3>
              <p class="offer-detail">Prezzi da 0.118 €/kWh</p>
            </div>
          </div>
          <div class="offer-btn-solid" style="background: #f59e0b; box-shadow: 0 8px 20px -6px rgba(245,158,11,0.5);">Confronta Tariffe Luce</div>
        </a>
        
        <a href="/gas" class="offer-card-premium">
          <div class="offer-card-top">
            <div class="icon-squircle" style="background: #fee2e2; color: #dc2626; font-size: 28px;">🔥</div>
            <div class="offer-headers">
              <h3 class="offer-name">Gas Naturale</h3>
              <p class="offer-detail">Prezzi da 0.41 €/Smc</p>
            </div>
          </div>
          <div class="offer-btn-solid" style="background: #ef4444; box-shadow: 0 8px 20px -6px rgba(239,68,68,0.5);">Scopri Offerte Gas</div>
        </a>

        <a href="/internet" class="offer-card-premium">
          <div class="offer-card-top">
            <div class="icon-squircle" style="background: #ede9fe; color: #7c3aed; font-size: 28px;">📡</div>
            <div class="offer-headers">
              <h3 class="offer-name">Internet Fibra</h3>
              <p class="offer-detail">FTTH fino a 5 Gbps</p>
            </div>
          </div>
          <div class="offer-btn-solid" style="background: #8b5cf6; box-shadow: 0 8px 20px -6px rgba(139,92,246,0.5);">Migliora Connessione</div>
        </a>

        <a href="/rc_auto" class="offer-card-premium">
          <div class="offer-card-top">
            <div class="icon-squircle" style="background: #fce7f3; color: #db2777; font-size: 28px;">🚗</div>
            <div class="offer-headers">
              <h3 class="offer-name">Assicurazione Auto</h3>
              <p class="offer-detail">Preventivo in 2 minuti</p>
            </div>
          </div>
          <div class="offer-btn-solid" style="background: #ec4899; box-shadow: 0 8px 20px -6px rgba(236,72,153,0.5);">Calcola RC Auto</div>
        </a>
      </div>

      <div class="offers-secondary">
        <a href="/istruzione" class="offer-mini">🎓 Rette Universitarie</a>
        <a href="/tfr_pensione" class="offer-mini">📊 Previdenza & TFR</a>
        <a href="/salute" class="offer-mini">🏥 Polizze Sanitarie</a>
      </div>

      <div class="transparency-box">
        <div class="transparency-icon">🛡️</div>
        <p>
          <strong>Impegno alla Trasparenza:</strong> Manteniamo la piattaforma gratuita e priva di banner pubblicitari invasivi grazie a selezionati link di affiliazione. Nessun ricarico sul tuo prezzo finale. <a href="/chi-siamo">Come funziona la nostra etica →</a>
        </p>
      </div>
    </section>

    <section id="gestisci" class="pillar">
      <div class="pillar-header">
        <span class="pillar-badge pillar-badge-purple">Control Center</span>
        <h2 class="pillar-title">Gestisci la tua Vita.</h2>
        <p class="pillar-sub">Il tuo hub finanziario domestico. Tutte le scadenze in un'unica plancia di comando.</p>
      </div>

      <div class="app-dashboard-wrapper">
        <div class="app-dashboard-bg"></div>
        <div class="app-dashboard-content">
          
          <div class="app-mock-ui">
            <div class="ios-notification">
              <div class="ios-icon" style="background: #fef2f2; color: #dc2626;">⚠️</div>
              <div class="ios-text">
                <strong>Bollo Auto in scadenza</strong>
                <span>Mancano 18 giorni al pagamento.</span>
              </div>
            </div>
            <div class="ios-notification">
              <div class="ios-icon" style="background: #f0fdf4; color: #166534;">💡</div>
              <div class="ios-text">
                <strong>Opportunità di Switch</strong>
                <span>La tua RCA scade tra 36 giorni. Trovate 3 offerte migliori.</span>
              </div>
            </div>
            <div class="ios-notification" style="opacity: 0.7; transform: scale(0.95) translateY(10px);">
              <div class="ios-icon" style="background: #eff6ff; color: #1e40af;">📋</div>
              <div class="ios-text">
                <strong>Documento in scadenza</strong>
                <span>Carta d'identità da rinnovare (4 mesi).</span>
              </div>
            </div>
          </div>

          <div class="app-lead-content">
            <h3 class="app-lead-title">Il tuo cruscotto è in arrivo.</h3>
            <p class="app-lead-desc">
              Stiamo costruendo l'hub definitivo per la gestione domestica. Promemoria intelligenti e monitoraggio dei contratti, tutto in automatico.
            </p>
            
            <div class="app-capture-box glass-panel">
              <p class="capture-title">Sblocca l'Accesso VIP 🔑</p>
              <p class="capture-sub">Inserisci l'email per entrare in lista d'attesa e ricevere SUBITO la nostra <strong>Checklist Salvavita in PDF</strong>.</p>
              <form class="capture-form" id="capture-form">
                <input type="email" id="capture-email" placeholder="nome@email.com" class="capture-input" required />
                <button type="submit" class="capture-btn">Invia PDF →</button>
              </form>
              <div id="capture-success" class="capture-ok" style="display: none;">
                <span style="font-size: 20px;">✅</span> Fatto! Controlla la tua inbox per il PDF.
              </div>
            </div>
            <a href="/bollo_revisione" class="app-cta-link">Nel frattempo, usa lo Scadenzario Auto Pubblico →</a>
          </div>

        </div>
      </div>
    </section>

    <section class="pillar" style="padding-bottom: 80px;">
      <NewsletterSignup client:load variant="compact" />
    </section>

  </div>

</Layout>

<script>
  // Lead capture form in Gestisci teaser (MANTIENE LA LOGICA ORIGINALE)
  var captureForm = document.getElementById('capture-form');
  if (captureForm) {
    captureForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var email = document.getElementById('capture-email').value;
      if (!email) return;
      try {
        await fetch('https://soldibuoni.it/.netlify/functions/subscribe-newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, nome: '', interessi: ['dashboard', 'checklist'] }),
        });
        document.getElementById('capture-form').style.display = 'none';
        document.getElementById('capture-success').style.display = 'flex';
      } catch (err) {
        alert('Errore. Riprova tra qualche secondo.');
      }
    });
  }
</script>

<style>
  /* ── GLOBALS PER INDEX ── */
  .icon-squircle {
    width: 60px; height: 60px; border-radius: 20px;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; flex-shrink: 0;
  }
  .glass-squircle {
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  }

  /* ── HERO (MESH & GLOW) ── */
  .hero {
    position: relative; background: #0A0F1C;
    padding: 100px 20px 80px; text-align: center;
    overflow: hidden; min-height: 540px; display: flex; align-items: center; justify-content: center;
  }
  .hero-bg-mesh {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    overflow: hidden; z-index: 0; pointer-events: none;
  }
  .mesh-blob {
    position: absolute; filter: blur(90px); border-radius: 50%; opacity: 0.6;
    animation: floatBlob 15s ease-in-out infinite alternate;
  }
  .blob-1 { top: -20%; left: -10%; width: 50vw; height: 50vw; background: rgba(5, 150, 105, 0.4); animation-delay: 0s; }
  .blob-2 { bottom: -20%; right: -10%; width: 40vw; height: 40vw; background: rgba(124, 58, 237, 0.4); animation-delay: -5s; }
  .blob-3 { top: 40%; left: 50%; width: 30vw; height: 30vw; background: rgba(59, 130, 246, 0.3); transform: translate(-50%, -50%); animation-delay: -10s; }
  @keyframes floatBlob { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(5%, 10%) scale(1.1); } }
  
  .hero-inner { position: relative; z-index: 1; max-width: 800px; width: 100%; margin: 0 auto; }
  
  .hero-pill-badge {
    display: inline-block; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
    color: #e2e8f0; font-size: 12px; font-weight: 700; padding: 6px 16px; border-radius: 100px;
    margin-bottom: 24px; letter-spacing: 0.5px; backdrop-filter: blur(12px);
  }
  
  .hero-title {
    font-family: 'Playfair Display', serif; font-size: 56px; font-weight: 800;
    color: #ffffff; line-height: 1.1; margin-bottom: 24px; letter-spacing: -1px;
  }
  .hero-accent {
    background: linear-gradient(to right, #34d399, #3b82f6);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    font-size: 18px; color: #94a3b8; line-height: 1.6; margin-bottom: 40px; font-weight: 400;
  }
  
  .hero-ctas { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .hero-btn-glow {
    background: var(--color-primary); color: #fff; font-size: 16px; font-weight: 700;
    padding: 16px 36px; border-radius: 100px;
    box-shadow: 0 0 30px rgba(5,150,105,0.6); transition: all 0.3s var(--ease-fluid);
  }
  .hero-btn-glow:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(5,150,105,0.8); }
  
  .hero-btn-glass {
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    backdrop-filter: blur(12px); color: #fff; font-size: 16px; font-weight: 600;
    padding: 16px 32px; border-radius: 100px; transition: all 0.3s var(--ease-fluid);
  }
  .hero-btn-glass:hover { background: rgba(255,255,255,0.15); transform: translateY(-2px); }

  /* ── TRUST STRIP (CENTERED) ── */
  .trust-strip { background: #fff; border-bottom: 1px solid rgba(0,0,0,0.04); padding: 16px 20px; }
  .trust-inner {
    max-width: 1080px; margin: 0 auto; display: flex; align-items: center; justify-content: center;
  }
  .trust-stars { display: flex; align-items: center; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .stars { color: #FBBF24; font-size: 18px; letter-spacing: 2px; text-shadow: 0 2px 8px rgba(251,191,36,0.4); }
  .trust-score { font-size: 14px; font-weight: 800; color: #0f172a; margin-right: 8px; }
  .trust-text { font-size: 13px; color: #64748b; }
  .trust-text strong { color: #0f172a; }

  /* ── PAGE CONTENT & PILLARS ── */
  .page-content { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
  .pillar { padding-top: 80px; }
  .pillar-header { margin-bottom: 40px; text-align: center; max-width: 600px; margin-left: auto; margin-right: auto; }
  .pillar-badge {
    display: inline-block; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 2px;
    padding: 6px 16px; border-radius: 100px; margin-bottom: 16px;
  }
  .pillar-badge-blue { background: rgba(59,130,246,0.1); color: #1d4ed8; }
  .pillar-badge-green { background: rgba(16,185,129,0.1); color: #047857; }
  .pillar-badge-purple { background: rgba(139,92,246,0.1); color: #6d28d9; }
  
  .pillar-title { font-family: 'Playfair Display', serif; font-size: 40px; font-weight: 800; color: #0f172a; margin-bottom: 12px; letter-spacing: -0.5px; }
  .pillar-sub { font-size: 16px; color: #64748b; line-height: 1.6; }

  /* ── TOOLS DUO (IMPARA) ── */
  .tools-duo { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
  .tool-card {
    display: flex; flex-direction: column; padding: 40px 32px; border-radius: 32px; color: #fff;
    text-decoration: none; transition: all 0.4s var(--ease-fluid); min-height: 280px; position: relative; overflow: hidden;
  }
  .tool-card:hover { transform: translateY(-6px); box-shadow: 0 24px 48px -12px rgba(0,0,0,0.2); }
  
  .tool-premium-dark { background: linear-gradient(145deg, #1e293b, #0f172a); }
  .tool-premium-emerald { background: linear-gradient(145deg, #065f46, #064e3b); }
  
  .tool-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px; }
  .tool-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; background: rgba(255,255,255,0.1); padding: 6px 14px; border-radius: 100px; backdrop-filter: blur(8px); }
  .tool-name { font-size: 28px; font-weight: 800; margin-bottom: 12px; font-family: 'Playfair Display',serif; letter-spacing: -0.5px; }
  .tool-desc { font-size: 15px; color: rgba(255,255,255,0.8); line-height: 1.6; flex: 1; font-weight: 400; }
  .tool-cta { font-size: 15px; font-weight: 700; margin-top: 24px; display: inline-flex; align-items: center; gap: 8px; color: #fff; }

  /* ── RESOURCES ROW ── */
  .resources-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .resource-card {
    display: flex; flex-direction: column; gap: 16px; background: #fff; border: 1px solid rgba(0,0,0,0.04);
    border-radius: 24px; padding: 24px; transition: all 0.4s var(--ease-fluid);
  }
  .resource-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px -10px rgba(0,0,0,0.06); border-color: rgba(0,0,0,0.08); }
  .resource-info strong { display: block; font-size: 15px; color: #0f172a; font-weight: 700; margin-bottom: 4px; }
  .resource-info span { display: block; font-size: 13px; color: #64748b; }

  /* ── OFFERS GRID (RISPARMIA) ── */
  .offers-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
  .offer-card-premium {
    background: #fff; border: 1px solid rgba(0,0,0,0.04); border-radius: 32px; padding: 32px;
    display: flex; flex-direction: column; justify-content: space-between; gap: 32px;
    transition: all 0.4s var(--ease-fluid); text-decoration: none; position: relative; overflow: hidden;
  }
  .offer-card-premium:hover { transform: translateY(-4px); box-shadow: 0 24px 48px -12px rgba(0,0,0,0.08); border-color: rgba(0,0,0,0.08); }
  .offer-card-top { display: flex; align-items: flex-start; gap: 20px; }
  .offer-name { font-size: 20px; font-weight: 800; color: #0f172a; margin-bottom: 6px; letter-spacing: -0.3px; }
  .offer-detail { font-size: 14px; color: #64748b; font-weight: 500; }
  .offer-btn-solid {
    text-align: center; color: #fff; font-size: 15px; font-weight: 700; padding: 16px 24px; border-radius: 16px;
    transition: all 0.3s var(--ease-fluid); width: 100%;
  }
  .offer-card-premium:hover .offer-btn-solid { transform: scale(1.02); }

  .offers-secondary { display: flex; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
  .offer-mini {
    flex: 1; min-width: 200px; background: #fff; border: 1px solid rgba(0,0,0,0.04); border-radius: 16px;
    padding: 16px; font-size: 14px; font-weight: 700; color: #475569; text-align: center; transition: all 0.3s var(--ease-fluid);
  }
  .offer-mini:hover { border-color: var(--color-primary); color: var(--color-primary); box-shadow: 0 10px 20px -5px rgba(0,0,0,0.05); transform: translateY(-2px); }

  .transparency-box { background: rgba(255,255,255,0.6); backdrop-filter: blur(12px); border-radius: 20px; padding: 20px 24px; border: 1px solid rgba(0,0,0,0.04); display: flex; gap: 16px; align-items: flex-start; }
  .transparency-icon { font-size: 24px; line-height: 1; }
  .transparency-box p { font-size: 13px; color: #64748b; line-height: 1.6; margin: 0; }
  .transparency-box a { color: var(--color-primary); font-weight: 600; text-decoration: none; }

  /* ── APP DASHBOARD TEASER (GESTISCI) ── */
  .app-dashboard-wrapper { position: relative; border-radius: 40px; overflow: hidden; background: #000; box-shadow: 0 30px 60px -15px rgba(0,0,0,0.2); }
  .app-dashboard-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #1e1b4b, #312e81, #4c1d95); opacity: 0.9; }
  .app-dashboard-bg::after { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at top right, rgba(139,92,246,0.4), transparent 50%); }
  .app-dashboard-content { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; padding: 60px; min-height: 480px; align-items: center; }
  
  .app-mock-ui { display: flex; flex-direction: column; gap: 12px; transform: perspective(1000px) rotateY(5deg) rotateX(2deg); transform-style: preserve-3d; }
  .ios-notification {
    background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.4); border-radius: 24px; padding: 16px 20px; display: flex; align-items: center; gap: 16px;
    box-shadow: 0 10px 30px -5px rgba(0,0,0,0.15); transition: transform 0.4s var(--ease-fluid); cursor: default;
  }
  .ios-notification:hover { transform: translateX(10px) scale(1.02); }
  .ios-icon { width: 44px; height: 44px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
  .ios-text strong { display: block; font-size: 15px; color: #0f172a; font-weight: 700; margin-bottom: 2px; }
