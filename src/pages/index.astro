---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
import HeroContact from '../components/HeroContact.jsx';
---

<Layout title="Soldi Buoni - I tuoi soldi spesi bene" description="Smetti di pagare più del dovuto. Guide, comparatori e strumenti completamente gratuiti per tagliare le spese fisse e semplificare le tue scelte finanziarie.">
  
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-inner">
      
      <div class="hero-left">
        <div>
          <h1>I tuoi soldi <em>spesi bene.</em></h1>
          <p>Smetti di pagare più del dovuto. Guide, comparatori e strumenti completamente gratuiti per tagliare le spese fisse e semplificare le tue scelte finanziarie.</p>
        </div>
        <div class="hero-left-bottom">
          <HeroContact client:load />
        </div>
      </div>

      <div class="hero-right">
        <div class="popular-tools">
          <h3>⚡ Gli strumenti più usati</h3>
          <a href="/tfr_pensione" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(20,184,166,.15);">📊</div>
            <span class="pop-tool-name">Confronta i fondi di investimento</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/trova-bonus" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(245,158,11,.15);">🎁</div>
            <span class="pop-tool-name">Trova bonus fiscale</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/mutuo" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(16,185,129,.15);">🏠</div>
            <span class="pop-tool-name">Simulatore mutui</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/bollo_revisione" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(236,72,153,.15);">🚗</div>
            <span class="pop-tool-name">Memo scadenze auto</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/calcolo-stipendio" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(99,102,241,.15);">💶</div>
            <span class="pop-tool-name">Calcolo stipendio lordo/netto</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/forfettario-vs-ordinario" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(139,92,246,.15);">📋</div>
            <span class="pop-tool-name">P. Iva: Forfettario vs Ordinario</span>
            <span class="pop-tool-arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-strip">
    <div class="trust-inner">
      <div class="trust-item">
        <div class="trust-icon">🔍</div>
        <div class="trust-text">
          <span class="trust-title">Trasparente</span>
          <span class="trust-sub">Quando consigliamo un'offerta, dichiariamo sempre se è in affiliazione</span>
        </div>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <div class="trust-icon">🏛️</div>
        <div class="trust-text">
          <span class="trust-title">Fonti ufficiali</span>
          <span class="trust-sub">Dati da ARERA, Banca d'Italia, ANIA e COVIP</span>
        </div>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <div class="trust-icon">🔄</div>
        <div class="trust-text">
          <span class="trust-title">Aggiornato mensilmente</span>
          <span class="trust-sub">Prezzi, tassi e offerte verificati ogni mese</span>
        </div>
      </div>
      <div class="trust-sep"></div>
      <div class="trust-item">
        <div class="trust-icon">💶</div>
        <div class="trust-text">
          <span class="trust-title">100% gratuito</span>
          <span class="trust-sub">Tutti gli strumenti, senza registrazione</span>
        </div>
      </div>
    </div>
  </div>


  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- SEZIONE 1: 🔥 SPESE FISSE                                        -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <span id="cats" style="display:block; position:relative; top:-64px;"></span>
  <section id="spese-fisse" class="theme-section theme-light">
    <div class="theme-inner">
      <div class="theme-header">
        <span class="section-eyebrow section-eyebrow-light" style="--eb-color:#f97316;">🔥 Spese Fisse</span>
        <h2>Taglia le bollette ricorrenti</h2>
        <p>Per ogni mercato trovi <strong>guida educational, comparatore e criteri di scelta</strong>: capisci come funziona prima di confrontare.</p>
      </div>

      <div class="theme-subheader">
        <span class="theme-sub-label">📊 Confronta & Capisci il mercato</span>
      </div>
      <div class="cats-grid">
        <a href="/luce-gas" class="cat-card" style="--cat-color:#f59e0b">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fef3c7;">⚡🔥</div>
          <h3>Luce & Gas</h3>
          <p>Mercato libero, prezzo fisso vs variabile, CRAS</p>
        </a>
        <a href="/internet" class="cat-card" style="--cat-color:#8b5cf6">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#ede9fe;">📡</div>
          <h3>Fibra & Internet</h3>
          <p>FTTH, FTTC e FWA: differenze e scelta giusta</p>
        </a>
        <a href="/conti-correnti" class="cat-card" style="--cat-color:#10b981">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#dcfce7;">💳</div>
          <h3>Conti Correnti</h3>
          <p>Canone, interessi, costi nascosti</p>
        </a>
        <a href="/rc_auto" class="cat-card" style="--cat-color:#ec4899">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fce7f3;">🚗</div>
          <h3>RC Auto</h3>
          <p>Massimali, franchigie e classi di merito</p>
        </a>
        <a href="/salute" class="cat-card" style="--cat-color:#ef4444">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fee2e2;">🏥</div>
          <h3>Polizze Sanitarie</h3>
          <p>Quando vale davvero l'integrativa</p>
        </a>
      </div>

      <div class="theme-subheader" style="margin-top: 36px;">
        <span class="theme-sub-label">⭐ Offerte recensite dal team</span>
      </div>
      <div class="recensioni-strip">
        <a href="/recensione-eni" class="rec-mini">
          <span class="rec-mini-ic">⚡</span>
          <span class="rec-mini-tx"><strong>Eni Plenitude</strong><em>Fixa Time Smart</em></span>
        </a>
        <a href="/recensione-windtre" class="rec-mini">
          <span class="rec-mini-ic">📡</span>
          <span class="rec-mini-tx"><strong>WindTre Super Fibra</strong><em>FTTH 2.5 Gbps</em></span>
        </a>
        <a href="/recensione-lyca" class="rec-mini">
          <span class="rec-mini-ic">📱</span>
          <span class="rec-mini-tx"><strong>Lyca Mobile</strong><em>5G · 150 GB</em></span>
        </a>
        <a href="/recensione-bbva" class="rec-mini">
          <span class="rec-mini-ic">💳</span>
          <span class="rec-mini-tx"><strong>BBVA Conto Online</strong><em>3% interessi · 6 mesi</em></span>
        </a>
        <a href="/recensione-hype" class="rec-mini">
          <span class="rec-mini-ic">💰</span>
          <span class="rec-mini-tx"><strong>Hype</strong><em>Carta conto · 3 piani</em></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- SEZIONE 2: 🏠 CASA, AUTO & FAMIGLIA                              -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section id="casa-auto-famiglia" class="theme-section theme-light theme-alt">
    <div class="theme-inner">
      <div class="theme-header">
        <span class="section-eyebrow section-eyebrow-light" style="--eb-color:#14b8a6;">🏠 Casa, Auto & Famiglia</span>
        <h2>Le grandi spese della vita</h2>
        <p>Strumenti per le decisioni che pesano di più: comprare casa, gestire l'auto, pianificare lo studio.</p>
      </div>

      <div class="cats-grid">
        <a href="/mutuo" class="cat-card" style="--cat-color:#10b981">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#dcfce7;">🏠</div>
          <h3>Simulatore Mutui</h3>
          <p>Rata, ammortamento, fisso vs variabile</p>
        </a>
        <a href="/affitto-vs-mutuo" class="cat-card" style="--cat-color:#059669">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#d1fae5;">⚖️</div>
          <h3>Affitto vs Mutuo</h3>
          <p>Il break-even tra affittare e comprare</p>
        </a>
        <a href="/bollo_revisione" class="cat-card" style="--cat-color:#ef4444">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fee2e2;">🚗</div>
          <h3>Memo Scadenze Auto</h3>
          <p>Bollo, revisione, tagliando, gomme</p>
        </a>
        <a href="/istruzione" class="cat-card" style="--cat-color:#6366f1">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#eef2ff;">🎓</div>
          <h3>Rette Universitarie</h3>
          <p>Stima tasse per facoltà e fascia ISEE</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- SEZIONE 3: 💼 LAVORO & TASSE                                     -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section id="lavoro-tasse" class="theme-section theme-light">
    <div class="theme-inner">
      <div class="theme-header">
        <span class="section-eyebrow section-eyebrow-light" style="--eb-color:#8b5cf6;">💼 Lavoro & Tasse</span>
        <h2>Busta paga e fisco</h2>
        <p>Capisci quanto resta in tasca e <strong>quali bonus ti spettano davvero</strong>. Strumenti tarati su normativa italiana 2026.</p>
      </div>

      <div class="cats-grid">
        <a href="/calcolo-stipendio" class="cat-card" style="--cat-color:#a5b4fc">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#e0e7ff;">💶</div>
          <h3>Stipendio Lordo/Netto</h3>
          <p>IRPEF, detrazioni, addizionali regionali</p>
        </a>
        <a href="/forfettario-vs-ordinario" class="cat-card" style="--cat-color:#818cf8">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#e0e7ff;">📋</div>
          <h3>Forfettario vs Ordinario</h3>
          <p>Quale regime conviene alla tua P.IVA</p>
        </a>
        <a href="/trova-bonus" class="cat-card" style="--cat-color:#ec4899">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fce7f3;">🎁</div>
          <h3>Trova Bonus Fiscale</h3>
          <p>Diagnosi delle agevolazioni a cui hai diritto</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- SEZIONE 4: 📈 INVESTI & PIANIFICA                                -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section id="investi" class="theme-section theme-light theme-alt">
    <div class="theme-inner">
      <div class="theme-header">
        <span class="section-eyebrow section-eyebrow-light" style="--eb-color:#3b82f6;">📈 Investi & Pianifica</span>
        <h2>Il tuo futuro finanziario</h2>
        <p>Far crescere quello che hai. Simulazioni su <strong>dati storici reali</strong> e fondi pensione COVIP ufficiali.</p>
      </div>

      <div class="cats-grid">
        <a href="/investimenti" class="cat-card" style="--cat-color:#3b82f6">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#dbeafe;">💼</div>
          <h3>Portafogli Modello</h3>
          <p>Asset allocation simulate su dati storici</p>
        </a>
        <a href="/interesse-composto" class="cat-card" style="--cat-color:#0ea5e9">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#e0f2fe;">📈</div>
          <h3>Interesse Composto</h3>
          <p>Come crescono i risparmi nel tempo</p>
        </a>
        <a href="/tfr_pensione" class="cat-card" style="--cat-color:#14b8a6">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#ccfbf1;">📊</div>
          <h3>Fondi Pensione & TFR</h3>
          <p>172 comparti COVIP con rendimenti reali</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- SEZIONE 5: 📖 INIZIA DA QUI & METODO  (sfondo dark)              -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <span id="tools" style="display:block; position:relative; top:-64px;"></span>
  <section id="metodo" class="all-tools">
    <div class="all-tools-glow"></div>
    <div class="all-tools-inner">
      <div class="all-tools-header">
        <span class="section-eyebrow section-eyebrow-dark">📖 Metodo & Guide</span>
        <h2>Inizia da qui, poi approfondisci</h2>
        <p>Non sai da dove cominciare? Fai la diagnosi in 2 minuti e segui il metodo SoldiBuoni.</p>
      </div>

      <a href="/quanto-spendo" class="tool-hero">
        <div class="tool-hero-main">
          <div class="tool-hero-icon">🧮</div>
          <div class="tool-hero-text">
            <span class="tool-hero-badge">Inizia da qui</span>
            <h3>Quanto Spendo?</h3>
            <p>Scopri il tuo profilo di spesa in 2 minuti. Capisci dove sprechi e quanto puoi risparmiare su luce, gas, internet, banca e assicurazioni.</p>
          </div>
        </div>
        <span class="tool-hero-cta">Inizia ora <span class="tool-hero-arrow">→</span></span>
      </a>

      <div class="tool-grid">
        <a href="/analisi-bolletta" class="tool-card">
          <div class="tool-card-icon" style="background:rgba(245,158,11,.14); color:#fbbf24;">🔍</div>
          <div class="tool-card-body">
            <div class="tool-card-title-row">
              <h4>Analizza Bolletta</h4>
              <span class="tool-card-tag tag-ai">AI</span>
            </div>
            <p>Scopri se paghi troppo luce e gas</p>
          </div>
          <span class="tool-card-arrow">→</span>
        </a>
        <a href="/guida-risparmio" class="tool-card">
          <div class="tool-card-icon" style="background:rgba(59,130,246,.14); color:#60a5fa;">📖</div>
