        </a>
        <a href="/recensione-windtre" class="tool-card">
          <div class="tool-card-icon" style="background:rgba(249,115,22,.14); color:#fb923c;">📡</div>
          <div class="tool-card-body">
            <div class="tool-card-title-row">
              <h4>WindTre Super Fibra</h4>
