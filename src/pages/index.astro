---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
import HeroContact from '../components/HeroContact.jsx';
---

<Layout title="Soldi Buoni — I tuoi soldi spesi bene." description="Strumenti, comparatori e guide indipendenti di finanza personale. Aggiornati mensilmente sui dati ufficiali ARERA, Banca d'Italia, ANIA e COVIP. Gratuiti, senza registrazione.">

  <!-- ═════════════════════════════════════════════════════════════ -->
  <!-- HERO — editoriale, asciutto, KPI di credibilità                -->
  <!-- ═════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-inner">

      <div class="hero-meta">
        <span class="hero-meta-item">N° 04 · Aprile 2026</span>
        <span class="hero-meta-sep"></span>
        <span class="hero-meta-item">Edizione mensile</span>
      </div>

      <h1 class="hero-title">
        I tuoi soldi<br>
        <span class="hero-title-em">spesi bene.</span>
      </h1>

      <p class="hero-sub">
        Strumenti di analisi, comparatori indipendenti e guide editoriali per la finanza personale italiana. Costruiti su dati ufficiali. <strong>Aggiornati ogni mese. Gratuiti, senza registrazione.</strong>
      </p>

      <div class="hero-ctas">
        <a href="/quanto-spendo" class="btn-primary">
          Inizia la diagnosi
          <span class="btn-arrow">→</span>
        </a>
        <a href="#strumenti" class="btn-secondary">Esplora gli strumenti</a>
      </div>

      <div class="hero-kpis">
        <div class="kpi">
          <div class="kpi-num">172</div>
          <div class="kpi-lbl">Comparti COVIP a confronto</div>
        </div>
        <div class="kpi">
          <div class="kpi-num">20+</div>
          <div class="kpi-lbl">Strumenti gratuiti di analisi</div>
        </div>
        <div class="kpi">
          <div class="kpi-num">2026</div>
          <div class="kpi-lbl">Normative fiscali aggiornate</div>
        </div>
        <div class="kpi">
          <div class="kpi-num">€0</div>
          <div class="kpi-lbl">Costi · niente registrazione</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═════════════════════════════════════════════════════════════ -->
  <!-- TRUST STRIP — barra di credibilità                             -->
  <!-- ═════════════════════════════════════════════════════════════ -->
  <div class="trust-strip">
    <div class="trust-inner">
      <div class="trust-item">
        <span class="trust-num">01</span>
        <div class="trust-text">
          <span class="trust-title">Indipendenza dichiarata</span>
          <span class="trust-sub">Ogni link in affiliazione è segnalato con #ADV</span>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-num">02</span>
        <div class="trust-text">
          <span class="trust-title">Fonti ufficiali</span>
          <span class="trust-sub">ARERA, Banca d'Italia, ANIA, COVIP, MEF</span>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-num">03</span>
        <div class="trust-text">
          <span class="trust-title">Aggiornamento mensile</span>
          <span class="trust-sub">Tassi, prezzi e offerte verificati ogni mese</span>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-num">04</span>
        <div class="trust-text">
          <span class="trust-title">100% gratuito</span>
          <span class="trust-sub">Tutti gli strumenti, senza registrazione</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═════════════════════════════════════════════════════════════ -->
  <!-- INIZIA DA QUI — le due diagnosi come porte d'ingresso          -->
  <!-- ═════════════════════════════════════════════════════════════ -->
  <section class="start-here">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow"><span class="eyebrow-num">i.</span><span class="eyebrow-bar"></span> Inizia da qui</span>
        <h2 class="section-h2 serif">Non sai da dove cominciare?</h2>
        <p class="section-lead">Due strumenti di diagnosi gratuiti in due minuti. Capisci dove spreca il tuo budget familiare, poi confronta soltanto ciò che serve.</p>
      </div>

      <div class="entry-grid">
        <a href="/quanto-spendo" class="entry-card">
          <div class="entry-card-top">
            <span class="entry-card-tag">Diagnosi guidata</span>
            <span class="entry-card-arrow">↗</span>
          </div>
          <h3 class="entry-card-title serif">Quanto spendo?</h3>
          <p class="entry-card-desc">Profilo di spesa familiare in due minuti. Confronto rispetto alla media nazionale ISTAT su luce, gas, internet, banca, assicurazioni. Identifica le voci con il maggior margine di risparmio.</p>
          <div class="entry-card-foot">
            <span class="entry-card-time">⌁ 2 minuti</span>
            <span class="entry-card-cta">Inizia ora →</span>
          </div>
        </a>

        <a href="/analisi-bolletta" class="entry-card entry-card-alt">
          <div class="entry-card-top">
            <span class="entry-card-tag">AI · Beta</span>
            <span class="entry-card-arrow">↗</span>
          </div>
          <h3 class="entry-card-title serif">Analizza la tua bolletta</h3>
          <p class="entry-card-desc">Carica una foto della bolletta luce o gas. L'analisi AI estrae €/kWh e €/Smc, li confronta con i prezzi medi ARERA e ti dice se stai pagando troppo. Niente registrazione.</p>
          <div class="entry-card-foot">
            <span class="entry-card-time">⌁ 30 secondi</span>
            <span class="entry-card-cta">Carica bolletta →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═════════════════════════════════════════════════════════════ -->
  <!-- TUTTI GLI STRUMENTI — riorganizzati in 4 macro-aree            -->
  <!-- ═════════════════════════════════════════════════════════════ -->
  <span id="strumenti" class="anchor"></span>
  <section class="tools-area">
    <div class="container">

      <div class="section-head section-head-center">
        <span class="eyebrow"><span class="eyebrow-num">ii.</span><span class="eyebrow-bar"></span> Strumenti</span>
        <h2 class="section-h2 serif">Costruiti per ogni momento decisionale</h2>
        <p class="section-lead">Per ogni voce di spesa, un percorso a tre passi: <em>capisci il mercato, confronta le opzioni, scegli ciò che serve a te</em>. Tutti gli strumenti usano dati pubblici o redazionali, mai dati commerciali del fornitore.</p>
      </div>

      <!-- AREA 01: SPESE FISSE -->
      <div class="tools-block">
        <div class="tools-block-head">
          <span class="tools-block-num">01</span>
          <div>
            <h3 class="tools-block-title serif">Spese fisse ricorrenti</h3>
            <p class="tools-block-sub">Le bollette mensili. Comparatori e guide al mercato libero, ai contratti e ai costi nascosti.</p>
          </div>
        </div>
        <div class="tools-grid tools-grid-5">
          <a href="/luce-gas" class="tool-card">
            <span class="tool-card-dot" style="background:#f59e0b"></span>
            <h4>Luce &amp; Gas</h4>
            <p>Mercato libero, prezzo fisso vs variabile, CRAS</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/internet" class="tool-card">
            <span class="tool-card-dot" style="background:#8b5cf6"></span>
            <h4>Fibra &amp; Internet</h4>
            <p>FTTH, FTTC e FWA: differenze e scelta giusta</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/conti-correnti" class="tool-card">
            <span class="tool-card-dot" style="background:#10b981"></span>
            <h4>Conti Correnti</h4>
            <p>Canone, interessi, costi nascosti</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/rc_auto" class="tool-card">
            <span class="tool-card-dot" style="background:#ec4899"></span>
            <h4>RC Auto</h4>
            <p>Massimali, franchigie, classi di merito</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/salute" class="tool-card">
            <span class="tool-card-dot" style="background:#ef4444"></span>
            <h4>Polizze Sanitarie</h4>
            <p>Quando vale davvero l'integrativa</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
        </div>
      </div>

      <!-- AREA 02: CASA, AUTO & FAMIGLIA -->
      <div class="tools-block">
        <div class="tools-block-head">
          <span class="tools-block-num">02</span>
          <div>
            <h3 class="tools-block-title serif">Casa, auto &amp; famiglia</h3>
            <p class="tools-block-sub">Le decisioni che pesano di più: comprare casa, gestire l'auto, pianificare lo studio.</p>
          </div>
        </div>
        <div class="tools-grid tools-grid-4">
          <a href="/mutuo" class="tool-card">
            <span class="tool-card-dot" style="background:#10b981"></span>
            <h4>Simulatore Mutui</h4>
            <p>Rata, ammortamento, fisso vs variabile</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/affitto-vs-mutuo" class="tool-card">
            <span class="tool-card-dot" style="background:#059669"></span>
            <h4>Affitto vs Mutuo</h4>
            <p>Il break-even tra affittare e comprare</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/bollo_revisione" class="tool-card">
            <span class="tool-card-dot" style="background:#ef4444"></span>
            <h4>Memo Scadenze Auto</h4>
            <p>Bollo, revisione, tagliando, gomme</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/istruzione" class="tool-card">
            <span class="tool-card-dot" style="background:#6366f1"></span>
            <h4>Rette Universitarie</h4>
            <p>Stima tasse per facoltà e fascia ISEE</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
        </div>
      </div>

      <!-- AREA 03: LAVORO & TASSE -->
      <div class="tools-block">
        <div class="tools-block-head">
          <span class="tools-block-num">03</span>
          <div>
            <h3 class="tools-block-title serif">Lavoro &amp; tasse</h3>
            <p class="tools-block-sub">Busta paga, fisco, agevolazioni. Strumenti tarati su normativa italiana 2026.</p>
          </div>
        </div>
        <div class="tools-grid tools-grid-3">
          <a href="/calcolo-stipendio" class="tool-card">
            <span class="tool-card-dot" style="background:#6366f1"></span>
            <h4>Stipendio Lordo / Netto</h4>
            <p>IRPEF, detrazioni, addizionali regionali</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/forfettario-vs-ordinario" class="tool-card">
            <span class="tool-card-dot" style="background:#818cf8"></span>
            <h4>Forfettario vs Ordinario</h4>
            <p>Quale regime conviene alla tua P.IVA</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/trova-bonus" class="tool-card">
            <span class="tool-card-dot" style="background:#ec4899"></span>
            <h4>Trova Bonus Fiscale</h4>
            <p>Diagnosi delle agevolazioni a cui hai diritto</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
        </div>
      </div>

      <!-- AREA 04: INVESTI & PIANIFICA -->
      <div class="tools-block">
        <div class="tools-block-head">
          <span class="tools-block-num">04</span>
          <div>
            <h3 class="tools-block-title serif">Investi &amp; pianifica</h3>
            <p class="tools-block-sub">Far crescere quello che hai. Simulazioni su <strong>dati storici reali</strong> e comparti COVIP ufficiali.</p>
          </div>
        </div>
        <div class="tools-grid tools-grid-3">
          <a href="/investimenti" class="tool-card">
            <span class="tool-card-dot" style="background:#3b82f6"></span>
            <h4>Portafogli Modello</h4>
            <p>Asset allocation simulate su dati storici</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/interesse-composto" class="tool-card">
            <span class="tool-card-dot" style="background:#0ea5e9"></span>
            <h4>Interesse Composto</h4>
            <p>Come crescono i risparmi nel tempo</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
          <a href="/tfr_pensione" class="tool-card">
            <span class="tool-card-dot" style="background:#14b8a6"></span>
            <h4>Fondi Pensione &amp; TFR</h4>
            <p>172 comparti COVIP con rendimenti reali</p>
            <span class="tool-card-go">Apri ↗</span>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═════════════════════════════════════════════════════════════ -->
  <!-- MANIFESTO + METODO — sezione scura, autorevole                 -->
  <!-- ═════════════════════════════════════════════════════════════ -->
  <section class="manifesto">
    <div class="manifesto-bg"></div>
    <div class="container">

      <div class="manifesto-inner">
        <span class="eyebrow eyebrow-light"><span class="eyebrow-num">iii.</span><span class="eyebrow-bar"></span> Metodo &amp; Manifesto</span>

        <h2 class="manifesto-title serif">
          Non vendiamo prodotti.<br>
          <span class="manifesto-title-em">Spieghiamo come scegliere.</span>
        </h2>

        <p class="manifesto-lead">
          Il nostro lavoro è leggere prospetti, fogli informativi e CRAS al posto tuo, tradurli in italiano, e mostrarti i numeri che contano. Quando un'offerta è in affiliazione lo diciamo. Quando un prodotto non ci convince, anche.
        </p>

        <div class="manifesto-grid">
          <a href="/guida-risparmio" class="manif-card">
            <span class="manif-card-tag">Guida</span>
            <h4 class="serif">Guida al risparmio 2026</h4>
            <p>Il metodo completo in 7 capitoli per riordinare le spese ricorrenti.</p>
            <span class="manif-card-cta">Leggi →</span>
          </a>
          <a href="/checklist" class="manif-card">
            <span class="manif-card-tag">Azione</span>
            <h4 class="serif">Checklist salvavita</h4>
            <p>12 azioni concrete, una al mese. Per chi vuole partire subito.</p>
            <span class="manif-card-cta">Scarica →</span>
          </a>
          <a href="/chi-siamo" class="manif-card">
            <span class="manif-card-tag">Redazione</span>
            <h4 class="serif">Chi siamo</h4>
            <p>Come finanziamo il sito, come lavoriamo, come puoi verificarci.</p>
            <span class="manif-card-cta">Scopri →</span>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═════════════════════════════════════════════════════════════ -->
  <!-- SELEZIONE DEL MESE — le offerte, in formato editoriale          -->
  <!-- ═════════════════════════════════════════════════════════════ -->
  <section class="picks">
    <div class="container">

      <div class="picks-head">
        <div>
          <span class="eyebrow"><span class="eyebrow-num">iv.</span><span class="eyebrow-bar"></span> Selezione del mese</span>
