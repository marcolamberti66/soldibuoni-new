---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
---

<Layout title="Soldi Buoni — Strumenti e Offerte per le tue Finanze" description="La tua plancia di comando per abbattere i costi, ricordare ogni scadenza e scegliere le migliori offerte di luce, gas, internet e assicurazioni.">
  
  <section class="hero">
    <div class="hero-bg-mesh">
      <div class="mesh-blob blob-1"></div>
      <div class="mesh-blob blob-2"></div>
      <div class="mesh-blob blob-3"></div>
    </div>
    <div class="hero-inner">
      <h1 class="hero-title">
        Spese fuori controllo? <br/>Riprendi in mano i tuoi <span class="hero-accent">soldi.</span>
      </h1>
      <p class="hero-sub">
        La tua plancia di comando per abbattere i costi di casa, ricordare ogni scadenza e non farti più fregare dal mercato.
      </p>
      <div class="hero-ctas">
        <a href="#strumenti" class="hero-btn-glow">Usa i Tool Gratuiti ↓</a>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP (onesta) ═══ -->
  <div class="trust-strip">
    <div class="trust-inner">
      <span class="trust-icon">🛡️</span>
      <span class="trust-text">Strumenti <strong>100% gratuiti</strong> · Nessuna registrazione · Dati aggiornati ogni settimana · <a href="/chi-siamo" style="color: #059669; text-decoration: underline;">Come funziona →</a></span>
    </div>
  </div>

  <div class="page-content">

    <!-- ═══ STRUMENTI (slider fixato) ═══ -->
    <section id="strumenti" class="pillar">
      <div class="pillar-header">
        <h2 class="pillar-title">I tuoi Strumenti Intelligenti</h2>
        <p class="pillar-sub">Diagnostica, calcola e ottimizza. Nessuna registrazione richiesta.</p>
      </div>

      <div class="slider-track">
        
        <a href="/analisi-bolletta" class="tool-card tool-featured">
          <div class="icon-squircle icon-featured">🔍</div>
          <h3 class="tool-name" style="color: #fff;">Analizza Bollette AI</h3>
          <p class="tool-desc" style="color: rgba(255,255,255,0.75);">Trascina il PDF. L'AI calcola all'istante quanti soldi stai regalando al fornitore.</p>
          <span class="tool-cta-label" style="color: #34d399;">Analizza ora →</span>
        </a>

        <a href="/quanto-spendo" class="tool-card">
          <div class="icon-squircle glass-squircle">🧮</div>
          <h3 class="tool-name">Quanto Spendo?</h3>
          <p class="tool-desc">Scopri in 60 secondi il tuo "tesoretto" nascosto e dove puoi ottimizzare.</p>
          <span class="tool-cta-label">Calcola →</span>
        </a>

        <a href="/checklist" class="tool-card">
          <div class="icon-squircle glass-squircle">✅</div>
          <h3 class="tool-name">Checklist Salvavita</h3>
          <p class="tool-desc">12 azioni concrete da spuntare per sbloccare fino a €4.000/anno.</p>
          <span class="tool-cta-label">Inizia →</span>
        </a>

        <a href="/guida-risparmio" class="tool-card">
          <div class="icon-squircle glass-squircle">📖</div>
          <h3 class="tool-name">Guida Risparmio 2026</h3>
          <p class="tool-desc">Le strategie pratiche per tagliare gli sprechi domestici quest'anno.</p>
          <span class="tool-cta-label">Leggi →</span>
        </a>

        <a href="/mutuo" class="tool-card">
          <div class="icon-squircle glass-squircle">🏠</div>
          <h3 class="tool-name">Simulatore Mutui</h3>
          <p class="tool-desc">Calcola la rata, l'ammortamento e scopri se ti conviene surrogare.</p>
          <span class="tool-cta-label">Simula →</span>
        </a>

        <a href="/bollo_revisione" class="tool-card">
          <div class="icon-squircle glass-squircle">🚗</div>
          <h3 class="tool-name">Memo Scadenze Auto</h3>
          <p class="tool-desc">Inserisci la targa, al bollo e alla revisione ci pensiamo noi via email.</p>
          <span class="tool-cta-label">Attiva →</span>
        </a>

        <a href="/carburante" class="tool-card">
          <div class="icon-squircle glass-squircle">⛽</div>
          <h3 class="tool-name">Analisi Mobilità</h3>
          <p class="tool-desc">Benzina, Diesel o Elettrico? Calcola il costo reale al chilometro.</p>
          <span class="tool-cta-label">Calcola →</span>
        </a>

      </div>
      <p class="slider-hint">← Scorri per vedere tutti gli strumenti →</p>
    </section>

    <!-- ═══ MERCATO (con prezzi e badge live) ═══ -->
    <section id="mercato" class="pillar pillar-market">
      <div class="pillar-header">
        <h2 class="pillar-title">Capire il mercato e scegliere</h2>
        <p class="pillar-sub">Offerte reali e trasparenti, aggiornate automaticamente. Scegli e inizia a risparmiare.</p>
      </div>

      <div class="market-grid">
        
        <a href="/luce-gas" class="market-card">
          <div class="market-top">
            <div class="icon-squircle" style="background: #fef3c7;">⚡🔥</div>
            <div>
              <h3 class="market-name">Luce & Gas</h3>
              <span class="market-price">Da €0.118/kWh · Da €0.41/Smc</span>
            </div>
          </div>
          <p class="market-desc">Smetti di pagare la fedeltà al vecchio fornitore. Scopri le tariffe migliori.</p>
          <div class="market-bottom">
            <span class="live-badge">● Dati Live</span>
            <span class="market-btn" style="background: #f59e0b;">Scopri le offerte →</span>
          </div>
        </a>

        <a href="/internet" class="market-card">
          <div class="market-top">
            <div class="icon-squircle" style="background: #ede9fe;">📡</div>
            <div>
              <h3 class="market-name">Fibra & Internet</h3>
              <span class="market-price">Da €17.69/mese · FTTH fino a 5 Gbps</span>
            </div>
          </div>
          <p class="market-desc">Naviga al massimo della velocità senza vincoli nascosti o costi modem esorbitanti.</p>
          <div class="market-bottom">
            <span class="live-badge">● Dati Live</span>
            <span class="market-btn" style="background: #8b5cf6;">Verifica copertura →</span>
          </div>
        </a>

        <a href="/rc_auto" class="market-card">
          <div class="market-top">
            <div class="icon-squircle" style="background: #fce7f3;">🚗</div>
            <div>
              <h3 class="market-name">RC Auto</h3>
              <span class="market-price">7 compagnie · Preventivo in 2 min</span>
            </div>
          </div>
          <p class="market-desc">Evita il rinnovo automatico. Confronta in 2 minuti e abbatti il premio annuale.</p>
          <div class="market-bottom">
            <span class="estimate-badge">📊 Stima di Mercato</span>
            <span class="market-btn" style="background: #ec4899;">Calcola Preventivo →</span>
          </div>
        </a>

        <a href="/conti-correnti" class="market-card">
          <div class="market-top">
            <div class="icon-squircle" style="background: #dcfce7;">💳</div>
            <div>
              <h3 class="market-name">Conti Correnti</h3>
              <span class="market-price">Zero spese · Cashback · Carte gratuite</span>
            </div>
          </div>
          <p class="market-desc">Zero spese, carte gratuite o conti remunerati con cashback. Scegli la banca perfetta.</p>
          <div class="market-bottom">
            <span class="estimate-badge">📊 Confronto</span>
            <span class="market-btn" style="background: #10b981;">Trova il tuo conto →</span>
          </div>
        </a>

        <a href="/tfr_pensione" class="market-card">
          <div class="market-top">
            <div class="icon-squircle" style="background: #e0f2fe;">📈</div>
            <div>
              <h3 class="market-name">Previdenza & TFR</h3>
              <span class="market-price">ISC da 0.15% · Rendimenti fino al 5.5%</span>
            </div>
          </div>
          <p class="market-desc">Fondi negoziali vs aperti. Scopri dove versare il TFR per massimizzare il rendimento fiscale.</p>
          <div class="market-bottom">
            <span class="estimate-badge">📊 Stima di Mercato</span>
            <span class="market-btn" style="background: #0ea5e9;">Confronta i fondi →</span>
          </div>
        </a>

        <a href="/salute" class="market-card">
          <div class="market-top">
            <div class="icon-squircle" style="background: #ffedd5;">🏥</div>
            <div>
              <h3 class="market-name">Polizze Sanitarie</h3>
              <span class="market-price">Da €25/mese · Base, Standard, Premium</span>
            </div>
          </div>
          <p class="market-desc">Proteggi la tua famiglia azzerando i costi del privato. Rimborso visite e ricoveri.</p>
          <div class="market-bottom">
            <span class="estimate-badge">📊 Confronto</span>
            <span class="market-btn" style="background: #f97316;">Vedi i pacchetti →</span>
          </div>
        </a>

        <a href="/istruzione" class="market-card">
          <div class="market-top">
            <div class="icon-squircle" style="background: #f3f4f6;">🎓</div>
            <div>
              <h3 class="market-name">Rette Universitarie</h3>
              <span class="market-price">10 facoltà · Pubbliche e private</span>
            </div>
          </div>
          <p class="market-desc">Quanto costa l'ateneo dei tuoi figli? Confronta le tasse universitarie in base al tuo ISEE.</p>
          <div class="market-bottom">
            <span class="estimate-badge">📊 Confronto</span>
            <span class="market-btn" style="background: #64748b;">Confronta rette →</span>
          </div>
        </a>

      </div>

      <div class="transparency-box">
        <p>
          <strong>🤝 Trasparenza:</strong> Alcuni link in questa sezione sono link di affiliazione.
          Quando acquisti tramite i nostri link, potremmo ricevere una commissione — senza costi aggiuntivi per te.
          <a href="/chi-siamo" style="color: #059669; text-decoration: underline;">Come guadagniamo →</a>
        </p>
      </div>
    </section>

    <!-- ═══ NEWSLETTER ═══ -->
    <section class="pillar" style="padding-bottom: 80px;">
      <NewsletterSignup client:load variant="compact" />
    </section>

  </div>

</Layout>

<style>
  /* ── GLOBALS ── */
  .icon-squircle {
    width: 56px; height: 56px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; flex-shrink: 0;
  }
  .glass-squircle {
    background: rgba(15,23,42,0.03); border: 1px solid rgba(0,0,0,0.05);
  }
  .icon-featured {
    background: rgba(255,255,255,0.15); font-size: 26px;
  }

  /* ── HERO ── */
  .hero {
    position: relative; background: #0A0F1C;
    padding: 100px 20px 80px; text-align: center;
    overflow: hidden; min-height: 480px; display: flex; align-items: center; justify-content: center;
  }
  .hero-bg-mesh {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    overflow: hidden; z-index: 0; pointer-events: none;
  }
  .mesh-blob {
    position: absolute; filter: blur(90px); border-radius: 50%; opacity: 0.6;
    animation: floatBlob 15s ease-in-out infinite alternate;
  }
  .blob-1 { top: -20%; left: -10%; width: 50vw; height: 50vw; background: rgba(5, 150, 105, 0.4); }
  .blob-2 { bottom: -20%; right: -10%; width: 40vw; height: 40vw; background: rgba(124, 58, 237, 0.4); animation-delay: -5s; }
  .blob-3 { top: 40%; left: 50%; width: 30vw; height: 30vw; background: rgba(59, 130, 246, 0.3); transform: translate(-50%, -50%); animation-delay: -10s; }
  @keyframes floatBlob { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(5%, 10%) scale(1.1); } }
  
  .hero-inner { position: relative; z-index: 1; max-width: 800px; width: 100%; margin: 0 auto; }
  .hero-title {
    font-family: 'Playfair Display', serif; font-size: 54px; font-weight: 800;
    color: #ffffff; line-height: 1.1; margin-bottom: 24px; letter-spacing: -1px;
  }
  .hero-accent {
    background: linear-gradient(to right, #34d399, #3b82f6);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    font-size: 18px; color: #94a3b8; line-height: 1.6; margin-bottom: 40px;
    font-weight: 400; max-width: 640px; margin-left: auto; margin-right: auto;
  }
  .hero-ctas { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .hero-btn-glow {
    background: #059669; color: #fff; font-size: 16px; font-weight: 700;
    padding: 16px 36px; border-radius: 100px;
    box-shadow: 0 0 30px rgba(5,150,105,0.5);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hero-btn-glow:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(5,150,105,0.7); }

  /* ── TRUST STRIP (onesta) ── */
  .trust-strip { background: #fff; border-bottom: 1px solid rgba(0,0,0,0.04); padding: 14px 20px; }
  .trust-inner {
    max-width: 1080px; margin: 0 auto;
    display: flex; justify-content: center; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .trust-icon { font-size: 18px; }
  .trust-text { font-size: 13px; color: #64748b; text-align: center; }
  .trust-text strong { color: #0f172a; }

  /* ── PAGE CONTENT ── */
  .page-content { max-width: 1080px; margin: 0 auto; }
  .pillar { padding-top: 80px; padding-left: 24px; padding-right: 24px; }
  .pillar-header { margin-bottom: 32px; text-align: left; }
  .pillar-title {
    font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 800;
    color: #0f172a; margin-bottom: 8px; letter-spacing: -0.5px;
  }
  .pillar-sub { font-size: 16px; color: #64748b; line-height: 1.6; }

  /* ── SLIDER (FIXATO) ── */
  .slider-track {
    display: flex; gap: 20px;
    overflow-x: auto; -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    padding: 10px 0 20px;
    margin: 0 -24px; padding-left: 24px; padding-right: 24px;
    scrollbar-width: none;
  }
  .slider-track::-webkit-scrollbar { display: none; }
  .slider-hint {
    text-align: center; font-size: 12px; color: #94a3b8;
    margin-top: 4px; font-style: italic;
  }

  .tool-card {
    flex: 0 0 230px; scroll-snap-align: start;
    background: #fff; border: 1px solid rgba(0,0,0,0.06); border-radius: 24px; padding: 24px;
    display: flex; flex-direction: column;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
  }
  .tool-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 32px -8px rgba(0,0,0,0.1);
    border-color: rgba(0,0,0,0.1);
  }
  .tool-featured {
    background: linear-gradient(135deg, #0f172a, #1e293b); border: none;
    box-shadow: 0 4px 20px rgba(15,23,42,0.3);
  }
  .tool-featured:hover { box-shadow: 0 16px 40px -8px rgba(15,23,42,0.5); }

  .tool-name { font-size: 17px; font-weight: 800; color: #0f172a; margin-bottom: 8px; }
  .tool-desc { font-size: 13px; color: #64748b; line-height: 1.5; flex: 1; }
  .tool-cta-label {
    font-size: 13px; font-weight: 700; color: #059669;
    margin-top: 14px; display: block;
  }

  /* ── MARKET GRID ── */
  .pillar-market { margin-top: 20px; padding-top: 60px; border-top: 1px solid rgba(0,0,0,0.06); }
  .market-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px; margin-bottom: 24px;
  }

  .market-card {
    background: #fff; border: 1px solid rgba(0,0,0,0.06); border-radius: 24px; padding: 24px;
    display: flex; flex-direction: column;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .market-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px -10px rgba(0,0,0,0.1);
    border-color: rgba(0,0,0,0.1);
  }
  .market-top { display: flex; align-items: center; gap: 14px; margin-bottom: 12px; }
  .market-name { font-size: 18px; font-weight: 800; color: #0f172a; margin-bottom: 2px; }
  .market-price { font-size: 12px; color: #059669; font-weight: 600; }
  .market-desc { font-size: 13px; color: #64748b; line-height: 1.6; margin-bottom: 16px; flex: 1; }

  .market-bottom {
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
  }
  .live-badge {
    font-size: 11px; font-weight: 700; color: #059669;
    background: #f0fdf4; padding: 4px 10px; border-radius: 8px;
    flex-shrink: 0;
  }
  .estimate-badge {
    font-size: 11px; font-weight: 700; color: #0284c7;
    background: #e0f2fe; padding: 4px 10px; border-radius: 8px;
    flex-shrink: 0;
  }
  .market-btn {
    color: #fff; font-size: 13px; font-weight: 700;
    padding: 10px 16px; border-radius: 12px;
    transition: all 0.2s; white-space: nowrap;
    box-shadow: 0 4px 12px -4px rgba(0,0,0,0.25);
  }
  .market-card:hover .market-btn { transform: scale(1.03); filter: brightness(1.08); }

  .transparency-box {
    background: #f8fafc; border-radius: 14px; padding: 16px 20px;
    border: 1px solid #e2e8f0; margin-top: 8px;
  }
  .transparency-box p { font-size: 12px; color: #64748b; line-height: 1.6; margin: 0; }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .hero { padding: 70px 20px 50px; min-height: auto; }
    .hero-title { font-size: 32px; }
    .hero-sub { font-size: 15px; }
    .hero-btn-glow { width: 100%; text-align: center; }
    .pillar { padding-top: 48px; }
    .pillar-title { font-size: 26px; }
    .tool-card { flex: 0 0 200px; padding: 20px; }
    .market-grid { grid-template-columns: 1fr; }
    .market-bottom { flex-direction: column; align-items: stretch; }
    .market-btn { text-align: center; }
  }
</style>
