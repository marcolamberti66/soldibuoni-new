---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
---

<Layout title="Soldi Buoni — Strumenti e Offerte per le tue Finanze" description="La tua plancia di comando per abbattere i costi, ricordare ogni scadenza e scegliere le migliori offerte di luce, gas, internet e assicurazioni.">
  
  <!-- ══════ HERO ══════ -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-inner">
      <div class="hero-left">
        <h1>Il tuo consulente finanziario <em>personale.</em></h1>
        <p>Guide, strumenti e comparazioni per aiutarti a prendere decisioni migliori per le tue finanze. Completamente gratis!</p>

        <div class="msg-box">
          <label>💬 Scrivici — ti rispondiamo entro 24h</label>
          <textarea class="msg-input" rows="2" placeholder="Es: Ho una bolletta da €180/mese, è troppo? Come posso risparmiare?"></textarea>
          <button class="msg-send">Invia messaggio →</button>
        </div>
      </div>

      <div class="hero-right">
        <div class="popular-tools">
          <h3>⚡ Gli strumenti più usati</h3>
          <a href="/tfr_pensione" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(20,184,166,.15);">📊</div>
            <span class="pop-tool-name">Confronta i fondi di investimento</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/trova-bonus" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(245,158,11,.15);">🎁</div>
            <span class="pop-tool-name">Trova bonus fiscale</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/mutuo" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(16,185,129,.15);">🏠</div>
            <span class="pop-tool-name">Simulatore mutui</span>
            <span class="pop-tool-arrow">→</span>
          </a>
          <a href="/bollo_revisione" class="pop-tool">
            <div class="pop-tool-icon" style="background:rgba(236,72,153,.15);">🚗</div>
            <span class="pop-tool-name">Memo scadenze auto</span>
            <span class="pop-tool-arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ PROOF BAR ══════ -->
  <div class="proof">
    <div class="proof-inner">
      <div class="proof-item"><span class="proof-n">8</span><span class="proof-l">Aree di spesa coperte</span></div>
      <div class="proof-d"></div>
      <div class="proof-item"><span class="proof-n">40+</span><span class="proof-l">Provider confrontati</span></div>
      <div class="proof-d"></div>
      <div class="proof-item"><span class="proof-n">172</span><span class="proof-l">Fondi pensione COVIP</span></div>
      <div class="proof-d"></div>
      <div class="proof-item"><span class="proof-n">12</span><span class="proof-l">Strumenti gratuiti</span></div>
    </div>
  </div>

  <!-- ══════ 8 CATEGORIE ══════ -->
  <section id="cats" class="cats">
    <div class="cats-inner">
      <div class="cats-header">
        <h2>Categorie di spesa</h2>
        <p>Per ogni categoria trovi una guida per capire il mercato, i criteri per fare la scelta giusta e uno strumento per semplificarti la vita.</p>
      </div>
      <div class="cats-grid">
        <a href="/luce-gas" class="cat-card" style="--cat-color:#f59e0b">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fef3c7;">⚡🔥</div>
          <h3>Luce & Gas</h3>
          <p>Confronta le migliori tariffe del mercato libero</p>
        </a>
        <a href="/internet" class="cat-card" style="--cat-color:#8b5cf6">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#ede9fe;">📡</div>
          <h3>Fibra & Internet</h3>
          <p>FTTH, FTTC e FWA a confronto senza vincoli</p>
        </a>
        <a href="/rc_auto" class="cat-card" style="--cat-color:#ec4899">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fce7f3;">🚗</div>
          <h3>RC Auto</h3>
          <p>Preventivo rapido tra le principali compagnie</p>
        </a>
        <a href="/tfr_pensione" class="cat-card" style="--cat-color:#14b8a6">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#ccfbf1;">📊</div>
          <h3>Previdenza & TFR</h3>
          <p>172 fondi COVIP con rendimenti ufficiali</p>
        </a>
        <a href="/conti-correnti" class="cat-card" style="--cat-color:#10b981">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#dcfce7;">💳</div>
          <h3>Conti Correnti</h3>
          <p>Zero spese, cashback e liquidità remunerata</p>
        </a>
        <a href="/interesse-composto" class="cat-card" style="--cat-color:#3b82f6">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#dbeafe;">📈</div>
          <h3>Investimenti</h3>
          <p>Simula l'interesse composto sui tuoi risparmi</p>
        </a>
        <a href="/salute" class="cat-card" style="--cat-color:#ef4444">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#fee2e2;">🏥</div>
          <h3>Polizze Sanitarie</h3>
          <p>Integrativa dentale, oculistica e ricoveri</p>
        </a>
        <a href="/istruzione" class="cat-card" style="--cat-color:#6366f1">
          <span class="cat-arrow">↗</span>
          <div class="cat-icon" style="background:#eef2ff;">🎓</div>
          <h3>Rette Universitarie</h3>
          <p>Stima tasse per facoltà e fascia ISEE</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════ 3 OFFERTE IN EVIDENZA ══════ -->
  <section class="offers">
    <div class="offers-inner">
      <div class="offers-header">
        <h2>Offerte in evidenza</h2>
        <p>Le migliori opportunità del momento selezionate per te.</p>
      </div>
      <div class="offers-grid">
        <div class="offer-card">
          <div class="offer-top">
            <div class="offer-icon" style="background:#dcfce7;">💳</div>
            <span class="offer-badge">Consigliato</span>
          </div>
          <h3>BBVA — Conto Online</h3>
          <p class="offer-price">Rendimento 3% lordo · Cashback 4% · Canone €0</p>
          <p class="offer-desc">Il conto più remunerativo del momento. Zero spese, zero vincoli, gestione 100% digitale.</p>
          <a href="https://www.bbva.it/persone/prodotti/conti/conto-online.html" target="_blank" rel="noopener noreferrer" class="offer-cta">Scopri l'offerta →</a>
        </div>
        <div class="offer-card">
          <div class="offer-top">
            <div class="offer-icon" style="background:#fef3c7;">⚡🔥</div>
            <span class="offer-badge">Luce + Gas</span>
          </div>
          <h3>Eni Plenitude — Combinata</h3>
          <p class="offer-price">Pacchetto Luce + Gas · Buono spesa 100€</p>
          <p class="offer-desc">Offerta combinata con gestione digitale e attivazione gratuita. Fixa Time Smart e Trend Casa.</p>
          <a href="https://www.awin1.com/cread.php?awinmid=9529&awinaffid=2811530" target="_blank" rel="noopener noreferrer" class="offer-cta">Scopri l'offerta →</a>
        </div>
        <div class="offer-card">
          <div class="offer-top">
            <div class="offer-icon" style="background:#e0f2fe;">💰</div>
            <span class="offer-badge">Bonus 25€</span>
          </div>
          <h3>Hype — Carta Conto</h3>
          <p class="offer-price">Canone €0 · Carta virtuale immediata</p>
          <p class="offer-desc">La carta conto smart n.1 in Italia. Gestione 100% da app, zero costi nascosti e bonus di benvenuto.</p>
          <a href="https://www.financeads.net/tc.php?t=82784C257247700T" target="_blank" rel="noopener noreferrer" class="offer-cta">Scopri l'offerta →</a>
        </div>
      </div>
      <div class="transparency-box">
        <p>
          <strong>🤝 Trasparenza:</strong> Alcuni link in questa sezione sono link di affiliazione. 
          Potremmo ricevere una commissione — senza costi aggiuntivi per te. 
          Questo ci permette di mantenere gli strumenti gratuiti. 
          <a href="/chi-siamo" style="color: var(--green-600); text-decoration: underline; font-weight: 600;">Scopri di più →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ══════ TUTTI GLI STRUMENTI ══════ -->
  <section id="tools" class="all-tools">
    <div class="all-tools-inner">
      <div class="all-tools-header">
        <h2>Tutti gli strumenti</h2>
        <p>Simula, calcola e ottimizza. Azioni rapide senza nessuna registrazione.</p>
      </div>
      <div class="tool-list">
        <a href="/analisi-bolletta" class="tool-bar">
          <div class="tool-bar-icon">🔍</div>
          <div class="tool-bar-content"><h4>Analizza Bollette AI</h4><p>Carica la bolletta e scopri quanto stai pagando in più rispetto al mercato.</p></div>
          <span class="tool-bar-tag">AI</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/quanto-spendo" class="tool-bar">
          <div class="tool-bar-icon">🧮</div>
          <div class="tool-bar-content"><h4>Quanto Spendo?</h4><p>Analisi completa delle spese domestiche in 60 secondi.</p></div>
          <span class="tool-bar-tag">Diagnostica</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/checklist" class="tool-bar">
          <div class="tool-bar-icon">✅</div>
          <div class="tool-bar-content"><h4>Checklist Salvavita</h4><p>12 azioni concrete per risparmiare fino a €4.000/anno.</p></div>
          <span class="tool-bar-tag">Guida</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/guida-risparmio" class="tool-bar">
          <div class="tool-bar-icon">📖</div>
          <div class="tool-bar-content"><h4>Guida Risparmio 2026</h4><p>Le strategie pratiche per eliminare ogni spreco domestico.</p></div>
          <span class="tool-bar-tag">Guida</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/mutuo" class="tool-bar">
          <div class="tool-bar-icon">🏠</div>
          <div class="tool-bar-content"><h4>Simulatore Mutui</h4><p>Calcola rata, ammortamento, confronta tasso fisso e variabile.</p></div>
          <span class="tool-bar-tag">Calcolatore</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/calcolo-stipendio" class="tool-bar">
          <div class="tool-bar-icon">💶</div>
          <div class="tool-bar-content"><h4>Calcolo Stipendio Netto</h4><p>Dal lordo al netto in un clic. Con IRPEF, contributi e detrazioni.</p></div>
          <span class="tool-bar-tag">Calcolatore</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/interesse-composto" class="tool-bar">
          <div class="tool-bar-icon">📈</div>
          <div class="tool-bar-content"><h4>Simulatore Interesse Composto</h4><p>Visualizza come crescono i tuoi risparmi nel tempo con diversi scenari.</p></div>
          <span class="tool-bar-tag">Calcolatore</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/trova-bonus" class="tool-bar">
          <div class="tool-bar-icon">🎁</div>
          <div class="tool-bar-content"><h4>Trova Bonus Fiscale</h4><p>Verifica le agevolazioni e i bonus a cui hai diritto in base alla tua situazione.</p></div>
          <span class="tool-bar-tag">Diagnostica</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/bollo_revisione" class="tool-bar">
          <div class="tool-bar-icon">🚗</div>
          <div class="tool-bar-content"><h4>Memo Scadenze Auto</h4><p>Bollo, revisione, tagliando e gomme: non dimenticare più nessuna scadenza.</p></div>
          <span class="tool-bar-tag">Gestione</span>
          <span class="tool-bar-arrow">→</span>
        </a>
        <a href="/tfr_pensione" class="tool-bar">
          <div class="tool-bar-icon">📊</div>
          <div class="tool-bar-content"><h4>Confronta Fondi Pensione</h4><p>172 comparti COVIP con rendimenti ufficiali su 1, 3, 5, 10 e 20 anni.</p></div>
          <span class="tool-bar-tag">Confronto</span>
          <span class="tool-bar-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════ NEWSLETTER ══════ -->
  <section class="cta-s">
    <NewsletterSignup client:load variant="compact" />
  </section>

</Layout>

<style>
  /* ══════ HERO ══════ */
  .hero {
    background: linear-gradient(170deg, var(--navy-900), var(--navy-800) 60%, var(--navy-700));
    padding: 32px;
    padding-bottom: 72px; /* extra per compensare la curva ::after di 40px */
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: -120px;
    right: -80px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 40px;
    background: var(--bg);
    border-radius: 40px 40px 0 0;
  }
  .hero-inner {
    max-width: 1100px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .hero-left h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 42px;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .hero-left h1 em {
    font-style: italic;
    color: var(--green-400);
  }
  .hero-left p {
    font-size: 16px;
    color: rgba(148,163,184,0.85);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 480px;
  }

  /* Message box */
  .msg-box {
    background: var(--white);
    border-radius: 14px;
    padding: 18px 20px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }
  .msg-box label {
    font-size: 12px;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    margin-bottom: 8px;
  }
  .msg-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 14px;
    font-family: inherit;
    outline: none;
    resize: none;
    color: var(--text-body);
    transition: border 0.2s;
  }
  .msg-input:focus { border-color: var(--green-600); }
  .msg-send {
    margin-top: 10px;
    width: 100%;
    background: var(--green-600);
    color: #fff;
    border: none;
    padding: 11px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s;
  }
  .msg-send:hover { background: #047857; }

  /* Popular tools */
  .hero-right { display: flex; flex-direction: column; gap: 16px; }
  .popular-tools {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 22px 20px;
    backdrop-filter: blur(8px);
  }
  .popular-tools h3 {
    font-size: 13px;
    font-weight: 700;
    color: var(--green-400);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 16px;
  }
  .pop-tool {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: all 0.2s;
  }
  .pop-tool:last-child { border-bottom: none; }
  .pop-tool:hover { padding-left: 4px; }
  .pop-tool-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }
  .pop-tool-name {
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    flex: 1;
  }
  .pop-tool-arrow {
    font-size: 14px;
    color: rgba(255,255,255,0.3);
    transition: all 0.2s;
  }
  .pop-tool:hover .pop-tool-arrow {
    color: var(--green-400);
    transform: translateX(3px);
  }

  /* ══════ PROOF BAR ══════ */
  .proof {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 18px 24px;
  }
  .proof-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 36px;
    flex-wrap: wrap;
  }
  .proof-item { text-align: center; }
  .proof-n {
    display: block;
    font-size: 22px;
    font-weight: 800;
    color: var(--navy-900);
    font-family: 'DM Serif Display', serif;
  }
  .proof-l { font-size: 11px; color: var(--text-muted); font-weight: 500; }
  .proof-d { width: 1px; height: 32px; background: var(--border); }

  /* ══════ CATEGORIE ══════ */
  .cats { padding: 48px 0 40px; }
  .cats-inner { max-width: 1100px; margin: 0 auto; padding: 0 28px; }
  .cats-header { margin-bottom: 28px; }
  .cats-header h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    color: var(--navy-900);
    margin-bottom: 6px;
  }
  .cats-header p { font-size: 15px; color: var(--text-muted); }

  .cats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .cat-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px 20px 22px;
    text-align: center;
    transition: all 0.35s var(--ease);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(12,35,64,0.03);
  }
  .cat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--cat-color);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s var(--ease);
  }
  .cat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, var(--cat-color), transparent 70%);
    opacity: 0;
    transition: opacity 0.35s var(--ease);
    pointer-events: none;
  }
  .cat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px -12px rgba(12,35,64,0.12);
    border-color: rgba(12,35,64,0.10);
  }
  .cat-card:hover::before { transform: scaleX(1); }
  .cat-card:hover::after { opacity: 0.04; }

  .cat-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    margin: 0 auto 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    transition: transform 0.35s var(--ease);
  }
  .cat-card:hover .cat-icon { transform: scale(1.08); }

  .cat-card h3 {
    font-size: 14px;
    font-weight: 800;
    color: var(--navy-900);
    margin-bottom: 4px;
    position: relative;
    z-index: 1;
  }
  .cat-card p {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.5;
    position: relative;
    z-index: 1;
  }
  .cat-card .cat-arrow {
    position: absolute;
    top: 12px;
    right: 14px;
    font-size: 14px;
    color: var(--text-light);
    transition: all 0.3s var(--ease);
    z-index: 1;
  }
  .cat-card:hover .cat-arrow {
    color: var(--cat-color);
    transform: translate(2px, -2px);
  }

  /* ══════ OFFERTE IN EVIDENZA ══════ */
  .offers { padding: 24px 0 48px; }
  .offers-inner { max-width: 1100px; margin: 0 auto; padding: 0 28px; }
  .offers-header { margin-bottom: 24px; }
  .offers-header h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 24px;
    color: var(--navy-900);
    margin-bottom: 4px;
  }
  .offers-header p { font-size: 14px; color: var(--text-muted); }

  .offers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .offer-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: all 0.3s var(--ease);
    border-left: 3px solid var(--green-600);
  }
  .offer-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px -8px rgba(12,35,64,0.1);
  }
  .offer-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .offer-icon {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .offer-badge {
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 3px 8px;
    border-radius: 5px;
    background: var(--green-50);
    color: var(--green-600);
    margin-left: auto;
  }
