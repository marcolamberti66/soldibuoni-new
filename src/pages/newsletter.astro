---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/NewsletterSignup.jsx';
---

<Layout title="Newsletter Risparmio Mensile | SoldiBuoni" description="Iscriviti alla newsletter gratuita. Ogni mese ricevi un report personalizzato con le migliori offerte e i consigli per risparmiare.">
  
  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <section style="max-width: 560px; margin: 0 auto; padding: 40px 20px 60px;">
    
    <div style="text-align: center; margin-bottom: 36px; animation: fadeIn 0.6s ease-out;">
      <span style="font-size: 48px; display: block; margin-bottom: 12px;">📬</span>
      <h1 style="font-family: 'Playfair Display', serif; font-size: 32px; color: #0f172a; margin-bottom: 10px; line-height: 1.2;">
        Report Risparmio Mensile
      </h1>
      <p style="font-size: 16px; color: #64748b; max-width: 460px; margin: 0 auto; line-height: 1.6;">
        Ogni mese nella tua inbox: come sono cambiati i prezzi, 
        dove puoi risparmiare, e le migliori offerte del momento.
      </p>
    </div>

    <NewsletterSignup client:load />

    <div style="margin-top: 32px;">
      <h3 style="font-family: 'Playfair Display',serif; font-size: 20px; color: #0f172a; margin-bottom: 16px; text-align: center;">
        Cosa ricevi ogni mese
      </h3>
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <div style="background: #fff; border-radius: 12px; padding: 18px 20px; border: 1px solid #e2e8f0; display: flex; gap: 14px; align-items: center;">
          <span style="font-size: 24px;">📊</span>
          <div>
            <p style="font-size: 14px; font-weight: 700; color: #0f172a;">Andamento prezzi</p>
            <p style="font-size: 13px; color: #64748b;">Come sono cambiati luce, gas e internet nell'ultimo mese</p>
          </div>
        </div>
        <div style="background: #fff; border-radius: 12px; padding: 18px 20px; border: 1px solid #e2e8f0; display: flex; gap: 14px; align-items: center;">
          <span style="font-size: 24px;">🏆</span>
          <div>
            <p style="font-size: 14px; font-weight: 700; color: #0f172a;">Migliori offerte</p>
            <p style="font-size: 13px; color: #64748b;">Le 3 offerte più convenienti per ogni categoria</p>
          </div>
        </div>
        <div style="background: #fff; border-radius: 12px; padding: 18px 20px; border: 1px solid #e2e8f0; display: flex; gap: 14px; align-items: center;">
          <span style="font-size: 24px;">💡</span>
          <div>
            <p style="font-size: 14px; font-weight: 700; color: #0f172a;">Consiglio del mese</p>
            <p style="font-size: 13px; color: #64748b;">Un'azione concreta per risparmiare, spiegata passo passo</p>
          </div>
        </div>
        <div style="background: #fff; border-radius: 12px; padding: 18px 20px; border: 1px solid #e2e8f0; display: flex; gap: 14px; align-items: center;">
          <span style="font-size: 24px;">📅</span>
          <div>
            <p style="font-size: 14px; font-weight: 700; color: #0f172a;">Scadenze importanti</p>
            <p style="font-size: 13px; color: #64748b;">Promemoria su bonus, detrazioni e deadline fiscali</p>
          </div>
        </div>
      </div>
    </div>

  </section>

</Layout>
