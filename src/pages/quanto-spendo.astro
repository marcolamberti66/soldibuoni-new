---
import Layout from '../layouts/Layout.astro';
import { QuantoSpendo } from '../components/QuantoSpendo.jsx';

const color = '#059669';
---

<Layout title="Quanto Spendo: wizard gratuito spese famiglia | SoldiBuoni" description="Scopri in 2 minuti quanto spendi all'anno in bollette, auto, casa e servizi. Confronto con la media italiana, piano d'azione e risparmio stimato. Privacy garantita: tutto nel tuo browser.">
  <div style="max-width: 960px; margin: 0 auto; padding: 36px 20px 80px;">

    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 10px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; background: ${color}14; flex-shrink: 0;`}>
        💸
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 30px; font-weight: 800; color: #0f172a; margin: 0;">
        <span style={`color: ${color};`}>Quanto Spendo</span>
      </h1>
    </div>

    <p class="update-note">🔄 Benchmark medie italiane 2025-2026 (fonti ARERA, ACI, ABI, ANIA) · Privacy-first: tutto resta nel tuo browser</p>

    <QuantoSpendo client:load color={color} />

  </div>
</Layout>

<style>
  .update-note {
    font-size: 12px;
    color: #94a3b8;
    margin: 0 0 28px 0;
    padding-left: 2px;
    font-weight: 500;
  }
</style>