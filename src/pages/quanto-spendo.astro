---
import Layout from '../layouts/Layout.astro';
import QuantoSpendo from '../components/QuantoSpendo.jsx';
---

<Layout title="Quanto Spendo? — Calcolatore Spesa Familiare | SoldiBuoni.it" description="Calcola la spesa annua della tua famiglia per luce, gas, internet, auto e università. Scopri quanto puoi risparmiare con le migliori offerte.">
  
  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <section style="max-width: 720px; margin: 0 auto; padding: 40px 20px 60px;">
    
    <div style="text-align: center; margin-bottom: 36px; animation: fadeIn 0.6s ease-out;">
      <span style="font-size: 48px; display: block; margin-bottom: 12px;">🧮</span>
      <h1 style="font-family: 'Playfair Display', serif; font-size: 32px; color: #0f172a; margin-bottom: 10px; line-height: 1.2;">
        Quanto spende la tua famiglia?
      </h1>
      <p style="font-size: 16px; color: #64748b; max-width: 500px; margin: 0 auto; line-height: 1.6;">
        Rispondi a 3 domande e scopri la tua spesa annua reale. 
        Ti mostriamo quanto puoi risparmiare con le offerte migliori di oggi.
      </p>
    </div>

    <QuantoSpendo client:load />

  </section>

</Layout>
