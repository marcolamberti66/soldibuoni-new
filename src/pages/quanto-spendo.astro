---
import Layout from '../layouts/Layout.astro';
import QuantoSpendo from '../components/QuantoSpendo.jsx';
---

<Layout title="Quanto Spendo? — Calcola la Spesa della tua Famiglia | SoldiBuoni" description="Calcola in 60 secondi quanto spende la tua famiglia all'anno tra bollette, auto e servizi. Scopri dove puoi risparmiare.">
  
  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <section style="max-width: 880px; margin: 0 auto; padding: 40px 20px 60px;">
    
    <div style="text-align: center; margin-bottom: 36px; animation: fadeIn 0.6s ease-out;">
      <span style="font-size: 48px; display: block; margin-bottom: 12px;">🧮</span>
      <h1 style="font-family: 'Playfair Display', serif; font-size: 32px; color: #0f172a; margin-bottom: 10px; line-height: 1.2;">
        Quanto spende la tua famiglia?
      </h1>
      <p style="font-size: 16px; color: #64748b; max-width: 500px; margin: 0 auto; line-height: 1.6;">
        3 domande, 60 secondi. Scopri la tua spesa annua 
        e quanto potresti risparmiare con le offerte migliori.
      </p>
    </div>

    <QuantoSpendo client:load />

  </section>

</Layout>
