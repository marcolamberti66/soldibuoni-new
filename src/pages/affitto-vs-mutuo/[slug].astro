---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const importi = [400, 450, 500, 550, 600, 650, 700, 800, 900, 1000, 1100, 1200, 1300, 1400, 1500, 1700, 2000, 2200, 2500, 3000];
  const cittaKeys = ['milano','roma','torino','napoli','firenze','bologna','genova','bari','verona','padova','brescia','bergamo','parma','modena','trieste','venezia','catania','palermo','cagliari','pisa'];
  
  const importiPaths = importi.map(function(a, idx) {
    return {
      params: { slug: a + "-euro" },
      props: {
        type: 'importo',
        affitto: a,
        prev: idx > 0 ? importi[idx-1] : null,
        next: (importi.length - 1) > idx ? importi[idx+1] : null,
        tutti: importi
      }
    };
  });

  const cittaPaths = cittaKeys.map(function(slug) {
    return {
      params: { slug: slug },
      props: { type: 'citta', slug: slug }
    };
  });

  return [...importiPaths, ...cittaPaths];
}

const { type } = Astro.props;

// Helper liberi dal simbolo < per evitare crash dell'AST Parser
function rataMensile(C, anni, tassoPerc) {
  const i = tassoPerc / 100 / 12;
  const n = anni * 12;
  return C * (i * Math.pow(1+i, n)) / (Math.pow(1+i, n) - 1);
}
function fmt(n) { return new Intl.NumberFormat('it-IT').format(n); }

// --- LOGICA IMPORTO ---
function calcolaImporto(affittoMensile) {
  const YIELD_ITALIA = 5.0;
  const ANTICIPO_PERC = 20;
  const TASSO_MUTUO = 3.20;
  const DURATA_MUTUO = 25;
  const REND_ANTICIPO = 3.0;
  const ISTAT = 1.5;
  const MANUTENZIONE = 1.0;
  const ORIZZONTE = 30;

  const prezzoTotale = (affittoMensile * 12) / (YIELD_ITALIA / 100);
  const anticipo = prezzoTotale * (ANTICIPO_PERC / 100);
  const importoMutuo = prezzoTotale - anticipo;
  const speseAcq = prezzoTotale * 0.06;
  const rata = rataMensile(importoMutuo, DURATA_MUTUO, TASSO_MUTUO);

  let costoAcqCum = anticipo + speseAcq;
  let costoAffCum = 0;
  let canoneCorrente = affittoMensile;
  let anticipoInvestito = anticipo;
  let breakEven = null;

  for (let anno = 1; ORIZZONTE >= anno; anno++) {
    const ratePagateNelleAnno = DURATA_MUTUO >= anno ? rata * 12 : 0;
    costoAcqCum += ratePagateNelleAnno + (prezzoTotale * (MANUTENZIONE / 100));
    costoAffCum += canoneCorrente * 12;
    canoneCorrente *= (1 + (ISTAT / 100));
    anticipoInvestito *= (1 + (REND_ANTICIPO / 100));
    const equity = DURATA_MUTUO >= anno ? importoMutuo * (anno / DURATA_MUTUO) : importoMutuo;
    const acqNetto = costoAcqCum - equity - anticipo;
    const affNetto = costoAffCum - (anticipoInvestito - anticipo);
    if (breakEven === null && affNetto > acqNetto) breakEven = anno;
  }
  return { prezzoTotale: Math.round(prezzoTotale), anticipo: Math.round(anticipo), speseAcq: Math.round(speseAcq), importoMutuo: Math.round(importoMutuo), rata: Math.round(rata), breakEven };
}

function stimaRal(rataMensileVal) {
  const nettoMensileNecessario = rataMensileVal / 0.30;
  const tabella = [[1100, 16500], [1330, 20000], [1526, 25000], [1723, 30000], [1919, 35000], [2115, 40000], [2310, 45000], [2506, 50000], [2700, 55000], [2891, 60000], [3270, 70000], [3647, 80000], [4025, 90000], [4403, 100000]];
  if (tabella[0][0] >= nettoMensileNecessario) return tabella[0][1];
  if (nettoMensileNecessario >= tabella[tabella.length - 1][0]) return Math.round(nettoMensileNecessario * 22.7);
  for (let i = 0; (tabella.length - 1) > i; i++) {
    if (nettoMensileNecessario >= tabella[i][0] && tabella[i + 1][0] >= nettoMensileNecessario) {
      const ratio = (nettoMensileNecessario - tabella[i][0]) / (tabella[i + 1][0] - tabella[i][0]);
      return Math.round(tabella[i][1] + ratio * (tabella[i + 1][1] - tabella[i][1]));
    }
  }
  return 0;
}

function ralLinkPiuVicino(ralStimata) {
  const RAL_DISP = [15000, 18000, 20000, 22000, 24000, 25000, 26000, 27000, 28000, 30000, 32000, 33000, 35000, 38000, 40000, 42000, 45000, 48000, 50000, 55000, 60000, 65000, 70000, 75000, 80000, 85000, 90000, 100000, 120000, 150000];
  let migliore = RAL_DISP[0];
  let diff = Math.abs(ralStimata - migliore);
  for (let i = 0; RAL_DISP.length > i; i++) {
    const d = Math.abs(ralStimata - RAL_DISP[i]);
    if (diff > d) { diff = d; migliore = RAL_DISP[i]; }
  }
  return migliore;
}

function importoMutuoPiuVicino(target) {
  const IMP_MUTUO = [50000, 60000, 70000, 80000, 90000, 100000, 110000, 120000, 130000, 140000, 150000, 160000, 170000, 180000, 190000, 200000, 220000, 240000, 250000, 270000, 280000, 300000, 320000, 350000, 380000, 400000, 420000, 450000, 480000, 500000];
  let migliore = IMP_MUTUO[0];
  let diff = Math.abs(target - migliore);
  for (let i = 0; IMP_MUTUO.length > i; i++) {
    const d = Math.abs(target - IMP_MUTUO[i]);
    if (diff > d) { diff = d; migliore = IMP_MUTUO[i]; }
  }
  return migliore;
}

// --- LOGICA CITTA ---
const CITTA = {
  'milano': { nome: 'Milano', regione: 'Lombardia', prezzoMq: 5400, affittoMq: 22.5, yield: 5.0, note: 'Tra le città più costose d\'Italia per l\'acquisto immobiliare' },
  'roma': { nome: 'Roma', regione: 'Lazio', prezzoMq: 3300, affittoMq: 16.5, yield: 6.0, note: 'Mercato molto frammentato tra zone centrali e periferiche' },
  'torino': { nome: 'Torino', regione: 'Piemonte', prezzoMq: 2200, affittoMq: 11.0, yield: 6.0, note: 'Tra le grandi città con miglior rapporto prezzo-qualità' },
  'napoli': { nome: 'Napoli', regione: 'Campania', prezzoMq: 2700, affittoMq: 12.5, yield: 5.5, note: 'Mercato in crescita, prezzi ancora moderati' },
  'firenze': { nome: 'Firenze', regione: 'Toscana', prezzoMq: 4100, affittoMq: 17.0, yield: 5.0, note: 'Pressione turistica significativa sui canoni e sui prezzi' },
  'bologna': { nome: 'Bologna', regione: 'Emilia-Romagna', prezzoMq: 3800, affittoMq: 17.5, yield: 5.5, note: 'Forte domanda studentesca sostiene i canoni di affitto' },
  'genova': { nome: 'Genova', regione: 'Liguria', prezzoMq: 2100, affittoMq: 10.5, yield: 6.0, note: 'Tra i prezzi più bassi delle grandi città italiane' },
  'bari': { nome: 'Bari', regione: 'Puglia', prezzoMq: 2300, affittoMq: 11.0, yield: 5.5, note: 'Mercato in crescita costante negli ultimi anni' },
  'verona': { nome: 'Verona', regione: 'Veneto', prezzoMq: 2900, affittoMq: 12.5, yield: 5.0, note: 'Mercato stabile con buona qualità della vita' },
  'padova': { nome: 'Padova', regione: 'Veneto', prezzoMq: 2700, affittoMq: 12.0, yield: 5.5, note: 'Polo universitario con domanda sostenuta di affitti' },
  'brescia': { nome: 'Brescia', regione: 'Lombardia', prezzoMq: 2400, affittoMq: 11.5, yield: 5.5, note: 'Beneficia della prossimità a Milano con prezzi inferiori' },
  'bergamo': { nome: 'Bergamo', regione: 'Lombardia', prezzoMq: 2800, affittoMq: 12.0, yield: 5.0, note: 'Mercato sostenuto dal pendolarismo verso Milano' },
  'parma': { nome: 'Parma', regione: 'Emilia-Romagna', prezzoMq: 2500, affittoMq: 11.0, yield: 5.5, note: 'Buon equilibrio tra prezzi e qualità della vita' },
  'modena': { nome: 'Modena', regione: 'Emilia-Romagna', prezzoMq: 2400, affittoMq: 10.5, yield: 5.5, note: 'Mercato stabile nel polo industriale emiliano' },
  'trieste': { nome: 'Trieste', regione: 'Friuli-Venezia Giulia', prezzoMq: 2300, affittoMq: 10.5, yield: 5.5, note: 'Tra i mercati meno volatili del Nord-Est' },
  'venezia': { nome: 'Venezia', regione: 'Veneto', prezzoMq: 4200, affittoMq: 18.0, yield: 5.0, note: 'Pressione turistica eccezionale sui prezzi del centro storico' },
  'catania': { nome: 'Catania', regione: 'Sicilia', prezzoMq: 1700, affittoMq: 8.0, yield: 5.5, note: 'Tra i mercati immobiliari più accessibili d\'Italia' },
  'palermo': { nome: 'Palermo', regione: 'Sicilia', prezzoMq: 1500, affittoMq: 7.5, yield: 6.0, note: 'Prezzi tra i più bassi tra i capoluoghi italiani' },
  'cagliari': { nome: 'Cagliari', regione: 'Sardegna', prezzoMq: 2400, affittoMq: 11.0, yield: 5.5, note: 'Mercato sostenuto dalla forte domanda turistica stagionale' },
  'pisa': { nome: 'Pisa', regione: 'Toscana', prezzoMq: 2700, affittoMq: 12.5, yield: 5.5, note: 'Polo universitario con domanda continua di affitti' }
};

function calcolaScenario(prezzoTotale, affittoMensile) {
  const ANTICIPO_PERC = 20;
  const TASSO_MUTUO = 3.20;
  const DURATA_MUTUO = 25;
  const REND_ANTICIPO = 3.0;
  const ISTAT = 1.5;
  const MANUTENZIONE = 1.0;
  const ORIZZONTE = 30;

  const anticipo = prezzoTotale * (ANTICIPO_PERC / 100);
  const importoMutuo = prezzoTotale - anticipo;
  const speseAcquisto = prezzoTotale * 0.06;
  const rata = rataMensile(importoMutuo, DURATA_MUTUO, TASSO_MUTUO);

  let costoAcquistoCum = anticipo + speseAcquisto;
  let costoAffittoCum = 0;
  let canoneCorrente = affittoMensile;
  let anticipoInvestito = anticipo;
  let breakEven = null;

  for (let anno = 1; ORIZZONTE >= anno; anno++) {
    const ratePagateNelleAnno = DURATA_MUTUO >= anno ? rata * 12 : 0;
    const manutenzioneAnnua = prezzoTotale * (MANUTENZIONE / 100);
    costoAcquistoCum += ratePagateNelleAnno + manutenzioneAnnua;
    costoAffittoCum += canoneCorrente * 12;
    canoneCorrente *= (1 + (ISTAT / 100));
    anticipoInvestito *= (1 + (REND_ANTICIPO / 100));
    
    const equityMutuo = DURATA_MUTUO >= anno ? importoMutuo * (anno / DURATA_MUTUO) : importoMutuo;
    const costoAcqNetto = costoAcquistoCum - equityMutuo - anticipo;
    const costoAffNetto = costoAffittoCum - (anticipoInvestito - anticipo);

    if (breakEven === null && costoAffNetto > costoAcqNetto) breakEven = anno;
  }
  return { rata: Math.round(rata), importoMutuo: Math.round(importoMutuo), anticipo: Math.round(anticipo), speseAcquisto: Math.round(speseAcquisto), breakEven };
}

// --- VARIABILI GLOBALI PER ENTRAMBI I TEMPLATE ---
let titleSeo = "";
let descrSeo = "";
const color = '#10b981';
let faqs = [];
let faqJsonLdString = "";
let verdetto = "";
let verdettoColor = "";
let verdettoIcon = "";

// Variabili Importo
let importoC = null;
let ralStimata = 0;
let ralLink = 0;
let mutuoLink = 0;

// Variabili Città
let citta = null;
let prezzoTotaleCitta = 0;
let affittoMensileCitta = 0;
let sc = null;
let altreCitta = [];

if (type === 'importo') {
  importoC = calcolaImporto(Astro.props.affitto);
  ralStimata = stimaRal(importoC.rata);
  ralLink = ralLinkPiuVicino(ralStimata);
  mutuoLink = importoMutuoPiuVicino(importoC.importoMutuo);

  if (importoC.breakEven === null) {
    verdetto = `Spendere ${Astro.props.affitto} €/mese di affitto, in media in Italia, equivale a non poter raggiungere il pareggio con un acquisto in 30 anni.`;
    verdettoColor = '#dc2626'; verdettoIcon = '⚖️';
  } else if (5 >= importoC.breakEven) {
    verdetto = `Se paghi ${Astro.props.affitto} € di affitto, comprare diventa più conveniente già dopo ${importoC.breakEven} anni di permanenza.`;
    verdettoColor = '#10b981'; verdettoIcon = '⚖️';
  } else if (10 >= importoC.breakEven) {
    verdetto = `Se paghi ${Astro.props.affitto} € di affitto, comprare conviene dopo ${importoC.breakEven} anni: orizzonte ragionevole per chi pensa di restare almeno una decade nella stessa casa.`;
    verdettoColor = '#f59e0b'; verdettoIcon = '⚖️';
  } else {
    verdetto = `Spendere ${Astro.props.affitto} € di affitto richiede ${importoC.breakEven} anni perché l'acquisto diventi più conveniente: l'affitto è la scelta razionale a meno di intenzioni di lungo periodo.`;
    verdettoColor = '#dc2626'; verdettoIcon = '⚖️';
  }

  titleSeo = `Affitto da ${Astro.props.affitto} euro al mese: meglio comprare casa? Calcolo`;
  descrSeo = `Se paghi ${Astro.props.affitto} €/mese di affitto, potresti comprare una casa da circa ${fmt(importoC.prezzoTotale)} € con rata di ${fmt(importoC.rata)} €/mese. Break-even: ${importoC.breakEven ? importoC.breakEven + ' anni' : 'oltre 30 anni'}.`;
  
  faqs = [
    { q: `Se pago ${Astro.props.affitto} euro di affitto, che mutuo posso permettermi?`, a: `Pagare ${Astro.props.affitto} €/mese di affitto è economicamente equivalente, in media nel mercato italiano (yield lordo 5%), a una casa del valore di circa ${fmt(importoC.prezzoTotale)} €. Per acquistarla con un anticipo del 20% (${fmt(importoC.anticipo)} €) avresti un mutuo di ${fmt(importoC.importoMutuo)} € con rata mensile di ${fmt(importoC.rata)} € a 25 anni al 3,20%. La rata sarà più alta dell'affitto (${fmt(importoC.rata - Astro.props.affitto)} € in più al mese) ma una parte di essa è capitale rimborsato che resta tuo.` },
    { q: `Conviene di più pagare ${Astro.props.affitto} di affitto o ${fmt(importoC.rata)} di rata mutuo?`, a: `Confrontare solo i due numeri è ingannevole. La rata mutuo include il capitale che rimborsi (e quindi resta nel tuo patrimonio), mentre l'affitto è 100% spesa. Però l'acquisto richiede ${fmt(importoC.anticipo + importoC.speseAcq)} € di liquidità iniziale (anticipo + spese), e ti carica di costi nascosti (manutenzione, IMU per seconde case, assicurazioni). Considerati tutti questi fattori, comprare diventa più conveniente dopo circa ${importoC.breakEven || 'oltre 30'} anni di permanenza nella stessa casa.` },
    { q: `Quale stipendio serve per sostenere un mutuo equivalente a ${Astro.props.affitto} di affitto?`, a: `Per la rata di ${fmt(importoC.rata)} €/mese serve un netto mensile di almeno ${fmt(Math.round(importoC.rata / 0.30))} €/mese (regola del 30%), equivalente a una RAL di circa ${fmt(ralStimata)} € lordi annui. Questa è la soglia minima richiesta dalle banche per concedere il mutuo.` },
    { q: `Quanto costa in totale 30 anni di affitto da ${Astro.props.affitto} euro al mese?`, a: `Pagando ${Astro.props.affitto} € al mese e ipotizzando una rivalutazione ISTAT del +1,5% annuo, dopo 30 anni avrai versato circa ${fmt(Math.round(Astro.props.affitto * 12 * (Math.pow(1.015, 30) - 1) / 0.015))} € in canoni. Questa cifra non considera che l'anticipo non versato per l'acquisto (${fmt(importoC.anticipo)} €), se investito al 3% annuo, varrebbe circa ${fmt(Math.round(importoC.anticipo * Math.pow(1.03, 30)))} € dopo 30 anni.` }
  ];
} else {
  citta = CITTA[Astro.props.slug];
  prezzoTotaleCitta = citta.prezzoMq * 80;
  affittoMensileCitta = citta.affittoMq * 80;
  sc = calcolaScenario(prezzoTotaleCitta, affittoMensileCitta);
  const chiaviCitta = Object.keys(CITTA);
  for (let k = 0; chiaviCitta.length > k; k++) {
    if (chiaviCitta[k] !== Astro.props.slug) {
      altreCitta.push({ slug: chiaviCitta[k], nome: CITTA[chiaviCitta[k]].nome });
    }
  }

  if (sc.breakEven === null) {
    verdetto = `A ${citta.nome} l'acquisto non raggiunge il pareggio nei 30 anni di simulazione: l'affitto resta più conveniente per chi non ha un orizzonte di lunghissimo periodo.`;
    verdettoColor = '#dc2626'; verdettoIcon = '🏃';
  } else if (5 >= sc.breakEven) {
    verdetto = `A ${citta.nome} comprare conviene già dopo ${sc.breakEven} anni: il rapporto prezzi/canoni rende l'acquisto la scelta naturale per chi pensa di restare nel medio periodo.`;
    verdettoColor = '#10b981'; verdettoIcon = '🏠';
  } else if (10 >= sc.breakEven) {
    verdetto = `A ${citta.nome} comprare diventa più conveniente dell'affitto dopo ${sc.breakEven} anni. Se hai un orizzonte di vita superiore al decennio nella stessa abitazione, l'acquisto conviene.`;
    verdettoColor = '#f59e0b'; verdettoIcon = '⚖️';
  } else {
    verdetto = `A ${citta.nome} il break-even arriva solo dopo ${sc.breakEven} anni: l'affitto è la scelta più razionale a meno di intenzioni di lungo-lunghissimo periodo nella stessa casa.`;
    verdettoColor = '#dc2626'; verdettoIcon = '🏃';
  }

  titleSeo = `Affitto vs Mutuo a ${citta.nome}: dopo quanti anni conviene comprare`;
  descrSeo = `${citta.nome}: 80 mq costano circa ${fmt(prezzoTotaleCitta)} € all'acquisto vs ${fmt(affittoMensileCitta)} €/mese di affitto. Break-even: ${sc.breakEven ? sc.breakEven + ' anni' : 'oltre 30 anni'}. Calcolo trasparente con dati OMI 2025.`;
  
  faqs = [
    { q: `Conviene comprare casa o restare in affitto a ${citta.nome}?`, a: sc.breakEven === null ? `In base ai dati OMI Q4 2025, a ${citta.nome} l'acquisto di un appartamento di 80 mq (circa ${fmt(prezzoTotaleCitta)} €) non raggiunge il pareggio rispetto all'affitto (circa ${fmt(affittoMensileCitta)} €/mese) nei 30 anni di simulazione. Il rapporto prezzi-canoni è troppo sbilanciato verso l'acquisto. Comprare conviene solo se prevedi di vivere nella stessa casa per oltre 30 anni o hai forti motivazioni patrimoniali (lasciare un immobile agli eredi).` : `In base ai dati OMI Q4 2025, a ${citta.nome} comprare diventa più conveniente dell'affitto dopo circa ${sc.breakEven} anni di permanenza nella stessa casa. Prima di quel momento, considerando rata mutuo, manutenzione, spese d'acquisto e costo opportunità dell'anticipo, l'affitto risulta economicamente preferibile.` },
    { q: `Quanto costa un appartamento di 80 mq a ${citta.nome}?`, a: `Secondo i dati OMI dell'Agenzia delle Entrate aggiornati al Q4 2025, un appartamento di tipologia civile in stato normale a ${citta.nome} costa mediamente ${fmt(citta.prezzoMq)} €/mq nelle zone semicentrali. Per 80 mq significa circa ${fmt(prezzoTotaleCitta)} € totali. Le zone centrali possono costare il 30-50% in più, le zone periferiche il 20-30% in meno.` },
    { q: `Qual è l'affitto medio di un appartamento di 80 mq a ${citta.nome}?`, a: `L'indagine OMI sui canoni di locazione indica un canone medio di ${citta.affittoMq} €/mq al mese a ${citta.nome} per un appartamento civile in stato normale (zone semicentrali). Per 80 mq si arriva a circa ${fmt(affittoMensileCitta)} €/mese. Anche qui, le zone centrali possono richiedere canoni significativamente più alti, soprattutto in città con forte pressione turistica.` },
    { q: `Qual è la rendita lorda di un investimento immobiliare a ${citta.nome}?`, a: `La rendita annuale lorda da locazione a ${citta.nome} è circa il ${citta.yield}% (canone annuo / prezzo d'acquisto). ${citta.note} Tieni presente che il rendimento netto, considerando IMU, manutenzione, periodi di sfitto e tasse sui canoni (cedolare secca al 21% o 26%), è significativamente inferiore — tipicamente 2-4 punti percentuali in meno.` },
    { q: `Quale stipendio serve per comprare casa a ${citta.nome}?`, a: `Per sostenere la rata di un mutuo da ${fmt(sc.importoMutuo)} € (acquistando un appartamento da ${fmt(prezzoTotaleCitta)} € con anticipo del 20%), serve un netto mensile di almeno ${fmt(Math.round(sc.rata / 0.30))} €/mese. Equivale a una RAL di circa ${fmt(Math.round(sc.rata / 0.30 * 22))} € lordi annui. Inoltre serve un capitale liquido iniziale di ${fmt(sc.anticipo + sc.speseAcquisto)} € (anticipo + spese accessorie).` }
  ];
}

faqJsonLdString = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question", "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
});
---

<Layout title={titleSeo} description={descrSeo}>
  <script type="application/ld+json" is:inline set:html={faqJsonLdString}></script>

  <div style="max-width: 880px; margin: 0 auto; padding: 36px 20px 80px;">

    <nav aria-label="breadcrumb" style="font-size: 13px; color: #64748b; margin-bottom: 18px;">
      <a href="/" style="color: #64748b; text-decoration: none;">Home</a>
      <span style="margin: 0 6px; color: #cbd5e1;">›</span>
      <a href="/affitto-vs-mutuo" style="color: #64748b; text-decoration: none;">Affitto vs Mutuo</a>
      <span style="margin: 0 6px; color: #cbd5e1;">›</span>
      <span style="color: #0f172a; font-weight: 600;">{type === 'importo' ? `${Astro.props.affitto} €/mese` : citta.nome}</span>
    </nav>

    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 8px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 26px; background: ${color}14; flex-shrink: 0;`}>
        🏠
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 28px; font-weight: 800; color: #0f172a; margin: 0; line-height: 1.2;">
        {type === 'importo' ? (
          <>Affitto da <span style={`color: ${color};`}>{Astro.props.affitto} €/mese</span>: meglio comprare?</>
        ) : (
          <>Affitto o Mutuo a <span style={`color: ${color};`}>{citta.nome}</span>?</>
        )}
      </h1>
    </div>
    
    <p style="color: #94a3b8; font-size: 13px; margin: 0 0 28px 0;">
      {type === 'importo' 
