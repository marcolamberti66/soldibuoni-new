---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export function getStaticPaths() {
  const cittaList = ["milano","roma","torino","napoli","firenze","bologna","genova","bari","verona","padova","brescia","bergamo","parma","modena","trieste","venezia","catania","palermo","cagliari","pisa"];
  const importiList = [400, 450, 500, 550, 600, 650, 700, 800, 900, 1000, 1100, 1200, 1300, 1400, 1500, 1700, 2000, 2200, 2500, 3000];

  const cittaPaths = cittaList.map(c => ({
    params: { slug: c },
    props: { type: 'citta', slug: c, tuttiImporti: importiList }
  }));

  const importiPaths = importiList.map(a => ({
    params: { slug: `${a}-euro` },
    props: { type: 'importo', affitto: a, tuttiImporti: importiList }
  }));

  return [...cittaPaths, ...importiPaths];
}

const { type, slug, affitto, tuttiImporti } = Astro.props;

function fmt(n) { return new Intl.NumberFormat('it-IT').format(n); }
function rataMensile(C, anni, tassoPerc) {
  const i = tassoPerc / 100 / 12;
  const n = anni * 12;
  return C * (i * Math.pow(1 + i, n)) / (Math.pow(1 + i, n) - 1);
}

const YIELD_ITALIA = 5.0;
const ANTICIPO_PERC = 20;
const TASSO_MUTUO = 3.20;
const DURATA_MUTUO = 25;
const REND_ANTICIPO = 3.0;
const ISTAT = 1.5;
const MANUTENZIONE = 1.0;
const ORIZZONTE = 30;

// Variabili globali per il template
let titleSeo = "";
let descrSeo = "";
let color = "#10b981";
let faqs = [];
let faqJsonLdString = "";
let verdetto = "";
let verdettoColor = "";
let verdettoIcon = "";

// Variabili di calcolo
let prezzoTotale = 0;
let anticipo = 0;
let importoMutuo = 0;
let speseAcquisto = 0;
let rata = 0;
let breakEven = null;

// Specifiche per Città
let cittaObj = null;
let affittoMensile = 0;
let altreCitta = [];

// Specifiche per Importo
let ralStimata = 0;
let ralLink = 0;
let mutuoLink = 0;

if (type === 'citta') {
  const CITTA_DATA = {
    "milano": { nome: "Milano", regione: "Lombardia", prezzoMq: 5400, affittoMq: 22.5, yield: 5.0, note: "Tra le città più costose d'Italia per l'acquisto" },
    "roma": { nome: "Roma", regione: "Lazio", prezzoMq: 3300, affittoMq: 16.5, yield: 6.0, note: "Mercato molto frammentato tra zone centrali e periferiche" },
    "torino": { nome: "Torino", regione: "Piemonte", prezzoMq: 2200, affittoMq: 11.0, yield: 6.0, note: "Ottimo rapporto prezzo-qualità" },
    "napoli": { nome: "Napoli", regione: "Campania", prezzoMq: 2700, affittoMq: 12.5, yield: 5.5, note: "Mercato in crescita, prezzi moderati" },
    "firenze": { nome: "Firenze", regione: "Toscana", prezzoMq: 4100, affittoMq: 17.0, yield: 5.0, note: "Pressione turistica sui canoni e sui prezzi" },
    "bologna": { nome: "Bologna", regione: "Emilia-Romagna", prezzoMq: 3800, affittoMq: 17.5, yield: 5.5, note: "Forte domanda studentesca sostiene i canoni" },
    "genova": { nome: "Genova", regione: "Liguria", prezzoMq: 2100, affittoMq: 10.5, yield: 6.0, note: "Tra i prezzi più bassi delle grandi città" },
    "bari": { nome: "Bari", regione: "Puglia", prezzoMq: 2300, affittoMq: 11.0, yield: 5.5, note: "Mercato in crescita costante" },
    "verona": { nome: "Verona", regione: "Veneto", prezzoMq: 2900, affittoMq: 12.5, yield: 5.0, note: "Mercato stabile con buona qualità della vita" },
    "padova": { nome: "Padova", regione: "Veneto", prezzoMq: 2700, affittoMq: 12.0, yield: 5.5, note: "Polo universitario con domanda sostenuta" },
    "brescia": { nome: "Brescia", regione: "Lombardia", prezzoMq: 2400, affittoMq: 11.5, yield: 5.5, note: "Beneficia della prossimità a Milano" },
    "bergamo": { nome: "Bergamo", regione: "Lombardia", prezzoMq: 2800, affittoMq: 12.0, yield: 5.0, note: "Mercato sostenuto dal pendolarismo verso Milano" },
    "parma": { nome: "Parma", regione: "Emilia-Romagna", prezzoMq: 2500, affittoMq: 11.0, yield: 5.5, note: "Buon equilibrio tra prezzi e qualità della vita" },
    "modena": { nome: "Modena", regione: "Emilia-Romagna", prezzoMq: 2400, affittoMq: 10.5, yield: 5.5, note: "Mercato stabile nel polo industriale" },
    "trieste": { nome: "Trieste", regione: "Friuli", prezzoMq: 2300, affittoMq: 10.5, yield: 5.5, note: "Tra i mercati meno volatili del Nord-Est" },
    "venezia": { nome: "Venezia", regione: "Veneto", prezzoMq: 4200, affittoMq: 18.0, yield: 5.0, note: "Pressione turistica eccezionale" },
    "catania": { nome: "Catania", regione: "Sicilia", prezzoMq: 1700, affittoMq: 8.0, yield: 5.5, note: "Tra i mercati più accessibili d'Italia" },
    "palermo": { nome: "Palermo", regione: "Sicilia", prezzoMq: 1500, affittoMq: 7.5, yield: 6.0, note: "Prezzi tra i più bassi tra i capoluoghi" },
    "cagliari": { nome: "Cagliari", regione: "Sardegna", prezzoMq: 2400, affittoMq: 11.0, yield: 5.5, note: "Mercato sostenuto dalla domanda turistica" },
    "pisa": { nome: "Pisa", regione: "Toscana", prezzoMq: 2700, affittoMq: 12.5, yield: 5.5, note: "Polo universitario con domanda continua" }
  };

  cittaObj = CITTA_DATA[slug];
  prezzoTotale = cittaObj.prezzoMq * 80;
  affittoMensile = cittaObj.affittoMq * 80;
  altreCitta = Object.entries(CITTA_DATA).filter(([s]) => s !== slug).map(([s, c]) => ({ slug: s, nome: c.nome }));
  
  anticipo = Math.round(prezzoTotale * (ANTICIPO_PERC / 100));
  importoMutuo = prezzoTotale - anticipo;
  speseAcquisto = Math.round(prezzoTotale * 0.06);
  rata = Math.round(rataMensile(importoMutuo, DURATA_MUTUO, TASSO_MUTUO));

  let costoAcquistoCum = anticipo + speseAcquisto;
  let costoAffittoCum = 0;
  let canoneCorrente = affittoMensile;
  let anticipoInvestito = anticipo;

  for (let anno = 1; anno <= ORIZZONTE; anno++) {
    const ratePagate = anno <= DURATA_MUTUO ? rata * 12 : 0;
    costoAcquistoCum += ratePagate + (prezzoTotale * (MANUTENZIONE / 100));
    costoAffittoCum += canoneCorrente * 12;
    canoneCorrente *= (1 + (ISTAT / 100));
    anticipoInvestito *= (1 + (REND_ANTICIPO / 100));
    const equityMutuo = anno <= DURATA_MUTUO ? importoMutuo * (anno / DURATA_MUTUO) : importoMutuo;
    if (breakEven === null && (costoAcquistoCum - equityMutuo - anticipo) < (costoAffittoCum - (anticipoInvestito - anticipo))) breakEven = anno;
  }

  if (breakEven === null) {
    verdetto = `A ${cittaObj.nome} l'acquisto non raggiunge il pareggio nei 30 anni di simulazione: l'affitto resta più conveniente per chi non ha un orizzonte di lunghissimo periodo.`;
    verdettoColor = "#dc2626"; verdettoIcon = "🏃";
  } else if (breakEven <= 5) {
    verdetto = `A ${cittaObj.nome} comprare conviene già dopo ${breakEven} anni: il rapporto prezzi/canoni rende l'acquisto la scelta naturale per chi pensa di restare nel medio periodo.`;
    verdettoColor = "#10b981"; verdettoIcon = "🏠";
  } else if (breakEven <= 10) {
    verdetto = `A ${cittaObj.nome} comprare diventa più conveniente dell'affitto dopo ${breakEven} anni. Se hai un orizzonte di vita superiore al decennio nella stessa abitazione, l'acquisto conviene.`;
    verdettoColor = "#f59e0b"; verdettoIcon = "⚖️";
  } else {
    verdetto = `A ${cittaObj.nome} il break-even arriva solo dopo ${breakEven} anni: l'affitto è la scelta più razionale a meno di intenzioni di lungo-lunghissimo periodo.`;
    verdettoColor = "#dc2626"; verdettoIcon = "🏃";
  }

  titleSeo = `Affitto vs Mutuo a ${cittaObj.nome}: dopo quanti anni conviene comprare`;
  descrSeo = `${cittaObj.nome}: 80 mq costano circa ${fmt(prezzoTotale)} € all'acquisto vs ${fmt(affittoMensile)} €/mese di affitto. Break-even: ${breakEven ? breakEven + " anni" : "oltre 30 anni"}. Calcolo dati OMI 2025.`;
  
  faqs = [
    { q: `Conviene comprare casa o restare in affitto a ${cittaObj.nome}?`, a: breakEven === null ? `In base ai dati OMI Q4 2025, a ${cittaObj.nome} l'acquisto non raggiunge il pareggio rispetto all'affitto nei 30 anni di simulazione.` : `In base ai dati OMI Q4 2025, a ${cittaObj.nome} comprare diventa più conveniente dell'affitto dopo circa ${breakEven} anni di permanenza.` },
    { q: `Quanto costa un appartamento di 80 mq a ${cittaObj.nome}?`, a: `Costa mediamente ${fmt(cittaObj.prezzoMq)} €/mq nelle zone semicentrali. Per 80 mq significa circa ${fmt(prezzoTotale)} € totali.` },
    { q: `Qual è l'affitto medio di 80 mq a ${cittaObj.nome}?`, a: `L'indagine OMI indica un canone medio di ${cittaObj.affittoMq} €/mq al mese. Per 80 mq si arriva a circa ${fmt(affittoMensile)} €/mese.` },
    { q: `Quale stipendio serve per comprare casa a ${cittaObj.nome}?`, a: `Per sostenere la rata di un mutuo da ${fmt(importoMutuo)} € serve un netto mensile di almeno ${fmt(Math.round(rata / 0.30))} €/mese (RAL di circa ${fmt(Math.round(rata / 0.30 * 22))} €).` }
  ];

} else if (type === 'importo') {
  
  prezzoTotale = Math.round((affitto * 12 * 100) / YIELD_ITALIA);
  anticipo = Math.round(prezzoTotale * (ANTICIPO_PERC / 100));
  importoMutuo = prezzoTotale - anticipo;
  speseAcquisto = Math.round(prezzoTotale * 0.06);
  rata = Math.round(rataMensile(importoMutuo, DURATA_MUTUO, TASSO_MUTUO));

  let costoAcqCum = anticipo + speseAcquisto;
  let costoAffCum = 0;
  let canoneCorrente = affitto;
  let anticipoInvestito = anticipo;

  for (let anno = 1; anno <= ORIZZONTE; anno++) {
    const ratePagate = anno <= DURATA_MUTUO ? rata * 12 : 0;
    costoAcqCum += ratePagate + (prezzoTotale * (MANUTENZIONE / 100));
    costoAffCum += canoneCorrente * 12;
    canoneCorrente *= (1 + (ISTAT / 100));
    anticipoInvestito *= (1 + (REND_ANTICIPO / 100));
    const equity = anno <= DURATA_MUTUO ? importoMutuo * (anno / DURATA_MUTUO) : importoMutuo;
    if (breakEven === null && (costoAcqCum - equity - anticipo) < (costoAffCum - (anticipoInvestito - anticipo))) breakEven = anno;
  }

  const nettoMensileNecessario = rata / 0.30;
  const tabella = [ [1100, 16500], [1330, 20000], [1526, 25000], [1723, 30000], [1919, 35000], [2115, 40000], [2310, 45000], [2506, 50000], [2700, 55000], [2891, 60000], [3270, 70000], [3647, 80000], [4025, 90000], [4403, 100000] ];
  if (nettoMensileNecessario <= tabella[0][0]) ralStimata = tabella[0][1];
  else if (nettoMensileNecessario >= tabella[tabella.length - 1][0]) ralStimata = Math.round(nettoMensileNecessario * 22.7);
  else {
    for (let i = 0; i < tabella.length - 1; i++) {
      if (nettoMensileNecessario >= tabella[i][0] && nettoMensileNecessario <= tabella[i + 1][0]) {
        const ratio = (nettoMensileNecessario - tabella[i][0]) / (tabella[i + 1][0] - tabella[i][0]);
        ralStimata = Math.round(tabella[i][1] + ratio * (tabella[i + 1][1] - tabella[i][1]));
      }
    }
  }

  const RAL_DISP = [15000, 18000, 20000, 22000, 24000, 25000, 26000, 27000, 28000, 30000, 32000, 33000, 35000, 38000, 40000, 42000, 45000, 48000, 50000, 55000, 60000, 65000, 70000, 75000, 80000, 85000, 90000, 100000, 120000, 150000];
  ralLink = RAL_DISP[0];
  let diffRal = Math.abs(ralStimata - ralLink);
  for (const r of RAL_DISP) { const d = Math.abs(ralStimata - r); if (d < diffRal) { diffRal = d; ralLink = r; } }

  const IMP_MUTUO = [50000, 60000, 70000, 80000, 90000, 100000, 110000, 120000, 130000, 140000, 150000, 160000, 170000, 180000, 190000, 200000, 220000, 240000, 250000, 270000, 280000, 300000, 320000, 350000, 380000, 400000, 420000, 450000, 480000, 500000];
  mutuoLink = IMP_MUTUO[0];
  let diffMutuo = Math.abs(importoMutuo - mutuoLink);
  for (const i of IMP_MUTUO) { const d = Math.abs(importoMutuo - i); if (d < diffMutuo) { diffMutuo = d; mutuoLink = i; } }

  if (breakEven === null) {
    verdetto = `Spendere ${affitto} €/mese di affitto equivale a non poter raggiungere il pareggio con un acquisto in 30 anni.`;
    verdettoColor = "#dc2626"; verdettoIcon = "⚖️";
  } else if (breakEven <= 5) {
    verdetto = `Se paghi ${affitto} € di affitto, comprare diventa più conveniente già dopo ${breakEven} anni di permanenza.`;
    verdettoColor = "#10b981"; verdettoIcon = "⚖️";
  } else if (breakEven <= 10) {
    verdetto = `Se paghi ${affitto} € di affitto, comprare conviene dopo ${breakEven} anni: orizzonte ragionevole per chi pensa di restare almeno una decade nella stessa casa.`;
    verdettoColor = "#f59e0b"; verdettoIcon = "⚖️";
  } else {
    verdetto = `Spendere ${affitto} € di affitto richiede ${breakEven} anni perché l'acquisto diventi più conveniente: l'affitto è la scelta razionale a meno di intenzioni di lungo periodo.`;
    verdettoColor = "#dc2626"; verdettoIcon = "⚖️";
  }

  titleSeo = `Affitto da ${affitto} euro al mese: meglio comprare casa? Calcolo`;
  descrSeo = `Se paghi ${affitto} €/mese di affitto, potresti comprare una casa da circa ${fmt(prezzoTotale)} € con rata di ${fmt(rata)} €/mese. Break-even: ${breakEven ? breakEven + " anni" : "oltre 30 anni"}.`;
  
  faqs = [
    { q: `Se pago ${affitto} euro di affitto, che mutuo posso permettermi?`, a: `Pagare ${affitto} €/mese è equivalente, in media (yield 5%), a una casa da ${fmt(prezzoTotale)} €. Per acquistarla avresti un mutuo di ${fmt(importoMutuo)} € con rata di ${fmt(rata)} € a 25 anni al 3,20%.` },
    { q: `Conviene di più pagare ${affitto} di affitto o ${fmt(rata)} di rata mutuo?`, a: `La rata mutuo include il capitale che rimborsi. Però l'acquisto richiede ${fmt(anticipo + speseAcquisto)} € di liquidità iniziale. Comprare diventa più conveniente dopo circa ${breakEven || 'oltre 30'} anni.` },
    { q: `Quale stipendio serve per sostenere un mutuo equivalente a ${affitto} di affitto?`, a: `Per la rata di ${fmt(rata)} €/mese serve un netto di almeno ${fmt(Math.round(rata / 0.30))} €/mese, equivalente a una RAL di circa ${fmt(ralStimata)} €.` },
    { q: `Quanto costa in totale 30 anni di affitto da ${affitto} euro al mese?`, a: `Pagando ${affitto} € al mese (+1,5% ISTAT), in 30 anni avrai versato circa ${fmt(Math.round(affitto * 12 * (Math.pow(1.015, 30) - 1) / 0.015))} €. L'anticipo non versato per l'acquisto, se investito al 3%, varrebbe circa ${fmt(Math.round(anticipo * Math.pow(1.03, 30)))} €.` }
  ];
}

faqJsonLdString = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
});
---

<Layout title={titleSeo} description={descrSeo}>
  <script type="application/ld+json" is:inline set:html={faqJsonLdString}></script>

  <div class="page-container">

    <nav aria-label="breadcrumb" class="breadcrumb">
      <a href="/">Home</a> <span class="sep">›</span>
      <a href="/affitto-vs-mutuo">Affitto vs Mutuo</a> <span class="sep">›</span>
      <span class="current">{type === 'citta' ? cittaObj.nome : `${affitto} €/mese`}</span>
    </nav>

    <div class="header-container">
      <div class="icon-box" style={`background: ${color}14;`}>🏠</div>
      <h1 class="main-title">
        {type === 'citta' ? (
          <>Affitto o Mutuo a <span style={`color: ${color};`}>{cittaObj.nome}</span>?</>
        ) : (
          <>Affitto da <span style={`color: ${color};`}>{affitto} €/mese</span>: meglio comprare?</>
        )}
      </h1>
    </div>
    
    {type === 'citta' ? (
      <p class="subtitle">{cittaObj.regione} · Dati OMI Agenzia delle Entrate Q4 2025</p>
    ) : (
      <p class="subtitle">Confronto basato su yield medio nazionale 5% · Tasso mutuo 3,20% · Anticipo 20%</p>
    )}

    <div class="verdetto-box" style={`background: linear-gradient(135deg, ${verdettoColor} 0%, ${verdettoColor}dd 100%);`}>
      <div class="verdetto-label">{verdettoIcon} {type === 'citta' ? 'Verdetto basato sui dati' : 'Verdetto'}</div>
      {breakEven !== null ? (
        <div class="verdetto-value">Pareggio: <span class="underline">{breakEven} anni</span></div>
      ) : (
        <div class="verdetto-value">Pareggio oltre 30 anni</div>
      )}
      <p class="verdetto-text">{verdetto}</p>
    </div>

    <div class="info-card">
      <h2 class="section-title" style={`color: ${color};`}>
        {type === 'citta' ? `I numeri di ${cittaObj.nome}` : `L'equivalente "comprato"`}
      </h2>
      <p class="section-desc">
        {type === 'citta' ? 'Per un appartamento civile di 80 mq in stato normale (zona semicentrale)' : 'Cosa potresti acquistare con la stessa "uscita" mensile, statisticamente in Italia:'}
      </p>
      
      <div class="kpi-grid">
        <div class="kpi-box">
          <div class="kpi-label">{type === 'citta' ? 'Prezzo acquisto medio' : 'Casa equivalente'}</div>
          <div class="kpi-value">€ {fmt(prezzoTotale)}</div>
          <div class="kpi-sub">{type === 'citta' ? `${fmt(cittaObj.prezzoMq)} €/mq` : '@ yield 5% lordo'}</div>
        </div>
        <div class="kpi-box">
          <div class="kpi-label">{type === 'citta' ? 'Affitto mensile medio' : 'Anticipo necessario'}</div>
          <div class="kpi-value">€ {type === 'citta' ? fmt(affittoMensile) : fmt(anticipo)}</div>
          <div class="kpi-sub">{type === 'citta' ? `${cittaObj.affittoMq} €/mq al mese` : '20% del prezzo'}</div>
        </div>
        <div class="kpi-box">
          <div class="kpi-label">{type === 'citta' ? 'Rendita lorda' : 'Rata mensile'}</div>
          <div class="kpi-value">{type === 'citta' ? `${cittaObj.yield}%` : `€ ${fmt(rata)}`}</div>
          <div class="kpi-sub">{type === 'citta' ? 'canone annuo / prezzo' : '25 anni @ 3,20%'}</div>
        </div>
        {type === 'importo' && (
          <div class="kpi-box">
            <div class="kpi-label">RAL minima</div>
            <div class="kpi-value">€ {fmt(ralStimata)}</div>
            <div class="kpi-sub">regola del 30%</div>
          </div>
        )}
      </div>
    </div>

    <div class="info-card">
      <h2 class="section-title" style={`color: ${color};`}>
        {type === 'citta' ? 'Scenario "Compro": tutti i numeri' : 'Confronto diretto: Affitto vs Mutuo'}
      </h2>
      
      {type === 'citta' ? (
        <>
          <div class="brk-row-info">
            <div class="brk-row border-none">
              <div>
                <div class="brk-label">Prezzo casa</div>
                <div class="brk-sub">80 mq × {fmt(cittaObj.prezzoMq)} €/mq</div>
              </div>
              <div class="brk-value">€ {fmt(prezzoTotale)}</div>
            </div>
          </div>
          <div class="brk-row">
            <div>
              <div class="brk-label">Anticipo necessario (20%)</div>
              <div class="brk-sub">Da avere liquido prima di accendere il mutuo</div>
            </div>
            <div class="brk-value">€ {fmt(anticipo)}</div>
          </div>
          <div class="brk-row">
            <div>
              <div class="brk-label">Spese acquisto (~6%)</div>
              <div class="brk-sub">Notaio + agenzia + imposte di registro</div>
            </div>
            <div class="brk-value">€ {fmt(speseAcquisto)}</div>
          </div>
          <div class="brk-row">
            <div>
              <div class="brk-label">Importo mutuo</div>
              <div class="brk-sub">Prezzo − anticipo</div>
            </div>
            <div class="brk-value">€ {fmt(importoMutuo)}</div>
          </div>
          <div class="brk-row-total">
            <div class="brk-row border-none">
              <div>
                <div class="brk-label" style="font-size: 16px;">Rata mensile (25 anni @ 3,20%)</div>
                <div class="brk-sub">Mutuo a tasso fisso</div>
              </div>
              <div class="brk-value" style={`font-size: 22px; color: ${color};`}>€ {fmt(rata)}</div>
            </div>
          </div>
        </>
      ) : (
        <>
          <div class="rate-grid">
            <div class="rate-box" style="border-left: 4px solid #dc2626;">
              <div class="rate-label">🏃 Resto in affitto</div>
              <div class="rate-row"><span>Spesa mensile</span><strong>€ {fmt(affitto)}</strong></div>
              <div class="rate-row"><span>Liquidità iniziale</span><span>€ 0</span></div>
              <div class="rate-row"><span>Equity dopo 25 anni</span><span>€ 0</span></div>
              <div class="rate-row"><span>Anticipo investito ne diventa</span><span>—</span></div>
              <div class="rate-row rate-row-total"><span>Tot. canoni 30 anni*</span><strong>€ {fmt(Math.round(affitto * 12 * (Math.pow(1.015, 30) - 1) / 0.015))}</strong></div>
            </div>
            <div class="rate-box" style={`border-left: 4px solid ${color};`}>
              <div class="rate-label">🏠 Compro casa</div>
              <div class="rate-row"><span>Rata mensile</span><strong>€ {fmt(rata)}</strong></div>
