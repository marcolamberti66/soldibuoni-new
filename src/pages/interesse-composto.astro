---
import Layout from '../layouts/Layout.astro';
import { InteresseComposto } from '../components/InteresseComposto.jsx';

const topic = {
  icon: '📈',
  title: 'Interesse Composto',
  color: '#8b5cf6'
};
---

<Layout title="Simulatore Interesse Composto | SoldiBuoni" description="Simula la crescita dei tuoi risparmi nel tempo. Scopri come piccoli versamenti mensili possono trasformarsi in un capitale enorme.">
  <div style="max-width: 880px; margin: 0 auto; padding: 36px 20px 80px;">
    
    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 28px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; background: ${topic.color}14;`}>
        {topic.icon}
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 30px; color: #0f172a;">
        {topic.title}
      </h1>
    </div>

    <InteresseComposto client:load color={topic.color} />

  </div>
</Layout>