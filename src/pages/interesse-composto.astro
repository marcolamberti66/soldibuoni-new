---
import Layout from '../layouts/Layout.astro';
import { InteresseComposto } from '../components/InteresseComposto.jsx';

const color = '#8b5cf6';
---

<Layout title="Simulatore Interesse Composto 2026 | SoldiBuoni" description="Simula la crescita dei risparmi nel tempo con PAC mensile, tassazione 26% e aggiustamento per inflazione. Scopri quanto conta davvero il valore reale del tuo capitale finale.">
  <div style="max-width: 880px; margin: 0 auto; padding: 36px 20px 80px;">

    <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 10px;">
      <div style={`width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; background: ${color}14; flex-shrink: 0;`}>
        📈
      </div>
      <h1 style="font-family: 'Playfair Display',serif; font-size: 30px; font-weight: 800; color: #0f172a; margin: 0;">
        Interesse <span style={`color: ${color};`}>Composto</span>
      </h1>
    </div>

    <p class="update-note">🔄 Include tassazione capital gain 26% e aggiustamento per inflazione 2% (target BCE)</p>

    <InteresseComposto client:only="react" color={color} />

  </div>
</Layout>

<style>
  .update-note {
    font-size: 12px;
    color: #94a3b8;
    margin: 0 0 28px 0;
    padding-left: 2px;
    font-weight: 500;
  }
</style>