---
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> 
  <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" /> 
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://soldibuoni.it">
  <meta name="google-site-verification" content="wuZor-nm95eBgdUml4_hB69hobDCJkqEDEdAoikBAbc" />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-H2JD077CTH"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-H2JD077CTH');
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      /* FIX: Sfondo meno abbagliante, più elegante (Slate 100) */
      --bg-body: #f1f5f9; 
      --text-main: #0f172a;
      --text-muted: #64748b;
      --color-primary: #059669;
      --ease-fluid: cubic-bezier(0.16, 1, 0.3, 1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { 
      background: var(--bg-body); 
      color: var(--text-main); 
      font-family: 'Inter', system-ui, -apple-system, sans-serif; 
      line-height: 1.6; 
      -webkit-font-smoothing: antialiased; 
    }
    a { text-decoration: none; color: inherit; }
    input[type="range"] { height: 6px; border-radius: 3px; }
    input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; cursor: pointer; }
    ::selection { background: var(--color-primary); color: #fff; }
    @keyframes slideUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); }}
  </style>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://soldibuoni.it/#website",
          "url": "https://soldibuoni.it/",
          "name": "Soldi Buoni",
          "description": "La tua plancia di comando per abbattere i costi e ottimizzare le finanze personali.",
          "inLanguage": "it-IT"
        },
        {
          "@type": "Organization",
          "@id": "https://soldibuoni.it/#organization",
          "name": "Soldi Buoni",
          "alternateName": "Soldibuoni.it",
          "url": "https://soldibuoni.it/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://soldibuoni.it/favicon-48.png"
          }
        }
      ]
    }
  </script>
</head>
<body style="min-height: 100vh; display: flex; flex-direction: column;">
  
  <nav id="main-nav" class="glass-nav">
    <a href="/" class="nav-logo">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink: 0;">
        <rect width="24" height="24" rx="8" fill="url(#paint0_linear)" />
        <path d="M14.5 9.5C14.5 8.11929 13.3807 7 12 7H10.5C9.11929 7 8 8.11929 8 9.5C8 10.8807 9.11929 12 10.5 12H13.5C14.8807 12 16 13.1193 16 14.5C16 15.8807 14.8807 17 13.5 17H12C10.6193 17 9.5 15.8807 9.5 14.5" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M12 5.5V18.5" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
        <defs>
          <linearGradient id="paint0_linear" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
            <stop stop-color="#10b981"/>
            <stop offset="1" stop-color="#047857"/>
          </linearGradient>
        </defs>
      </svg>
      Soldi Buoni
    </a>
    
    <div class="nav-links-desktop">
      <a href="/#impara" class="nav-pill nav-pill-blue">📚 Strumenti</a>
      <a href="/#risparmia" class="nav-pill nav-pill-green">💸 Confronta</a>
      <a href="/#gestisci" class="nav-pill nav-pill-purple">
        📊 Gestisci
        <span class="nav-soon">soon</span>
      </a>
    </div>

    <button id="menu-toggle" class="menu-toggle" aria-label="Menu">
      <span></span><span>