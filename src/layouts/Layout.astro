  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png?v=7" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=7" />

  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://soldibuoni.it">
  <meta property="og:image" content="https://soldibuoni.it/apple-touch-icon.png?v=6">
  <meta name="google-site-verification" content="wuZor-nm95eBgdUml4_hB69hobDCJkqEDEdAoikBAbc" />

  <script is:inline>
    (function() {
      var consent = null;
      try { consent = localStorage.getItem('sb_cookie_consent'); } catch(e) {}
      if (consent === 'accepted') {
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-H2JD077CTH';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-H2JD077CTH');
