  <style is:global>
    :root {
      /* Palette editoriale */
      --paper:        #f8f5ef;   /* panna caldo, sfondo principale */
      --paper-2:      #f3efe6;   /* panna leggermente più scuro per alternanze */
      --ink:          #0b1d33;   /* navy profondo, testo principale */
      --ink-soft:     #1f2e44;
      --ink-mid:      #4a5568;
      --ink-mute:     #768094;
      --ink-faint:    #a5adbb;
      --line:         rgba(11,29,51,0.10);
      --line-soft:    rgba(11,29,51,0.06);
      --white:        #ffffff;
      --gold:         #a07a2b;   /* accent editoriale per marker, numerazioni, dettagli */
      --gold-soft:    rgba(160,122,43,0.10);
      --gold-line:    rgba(160,122,43,0.30);
      --green:        #0f7a52;   /* azione/CTA */
      --green-dark:   #0a5d3e;
      --green-soft:   rgba(15,122,82,0.08);

      /* Compat con vecchie classi */
      --bg:           var(--paper);
      --navy-900:     var(--ink);
      --navy-800:     #122d4f;
      --navy-700:     #1a3a5c;
      --navy-50:      #f0f5ff;
      --green-600:    var(--green);
      --green-400:    #34d399;
      --green-50:     var(--green-soft);
      --text-dark:    var(--ink);
      --text-body:    var(--ink-soft);
      --text-muted:   var(--ink-mute);
      --text-light:   var(--ink-faint);
      --border:       var(--line);

      --ease: cubic-bezier(0.16, 1, 0.3, 1);
      --serif: 'Fraunces', 'DM Serif Display', Georgia, serif;
      --sans:  'Inter', system-ui, -apple-system, sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      background: var(--paper);
      color: var(--ink-soft);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    a { text-decoration: none; color: inherit; }
    ::selection { background: var(--ink); color: var(--paper); }

    /* Tipografia editoriale d'utilità */
    .serif { font-family: var(--serif); font-feature-settings: "ss01","ss02"; }
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2.4px;
      text-transform: uppercase;
      color: var(--gold);
    }
    .eyebrow .eyebrow-num {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 500;
      font-size: 13px;
      letter-spacing: 0;
      color: var(--gold);
      text-transform: none;
    }
    .eyebrow .eyebrow-bar {
      width: 28px;
      height: 1px;
      background: var(--gold-line);
    }
  </style>

  <script type="application/ld+json">
    {
