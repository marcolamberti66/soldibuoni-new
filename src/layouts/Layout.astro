  <style is:global>
    :root {
      --bg: #f8fafc;
      --white: #ffffff;
      --navy-900: #0c2340;
      --navy-800: #122d4f;
      --navy-700: #1a3a5c;
      --navy-50: #f0f5ff;
      --green-600: #059669;
      --green-400: #34d399;
      --green-50: #ecfdf5;
      --text-dark: #0f172a;
      --text-body: #334155;
      --text-muted: #64748b;
      --text-light: #94a3b8;
      --border: rgba(12,35,64,0.06);
      --ease: cubic-bezier(0.16, 1, 0.3, 1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { 
      background: var(--bg); 
      color: var(--text-body);
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif; 
      line-height: 1.6; 
      -webkit-font-smoothing: antialiased; 
    }
    a { text-decoration: none; color: inherit; }
    ::selection { background: var(--green-600); color: #fff; }
  </style>

  <script type="application/ld+json">
    {
